---
interface Props {
  slug: string;
  title: string;
  description?: string;
  category: string;
  resolution: string;
  duration: number;
  thumbnail?: string;
  price: { web: number };
  featured?: boolean;
}

const {
  slug,
  title,
  description,
  category,
  resolution,
  duration,
  thumbnail,
  price,
  featured = false,
} = Astro.props;

const categoryLabels: Record<string, string> = {
  business:    'Business',
  natur:       'Natur',
  lifestyle:   'Lifestyle',
  architektur: 'Architektur',
  technologie: 'Technologie',
  sport:       'Sport',
};

const formatDuration = (s: number) => {
  const m = Math.floor(s / 60);
  const sec = s % 60;
  return m > 0 ? `${m}:${sec.toString().padStart(2, '0')} min` : `${sec} Sek.`;
};
---

<article class={`video-card card ${featured ? 'video-card--featured' : ''}`}>
  <a href={`/video/${slug}`} class="video-card__media-link" aria-label={`Video ansehen: ${title}`} tabindex="-1">
    <div class="video-card__media">
      {thumbnail ? (
        <img
          src={thumbnail}
          alt={`Vorschau: ${title}`}
          loading="lazy"
          width="400"
          height="225"
          class="video-card__thumb"
        />
      ) : (
        <div class="video-card__placeholder" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <polygon points="5,3 19,12 5,21"/>
          </svg>
        </div>
      )}
      <div class="video-card__overlay" aria-hidden="true">
        <div class="video-card__play">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <polygon points="5,3 19,12 5,21"/>
          </svg>
        </div>
      </div>
      <div class="video-card__badges" aria-hidden="true">
        <span class="video-card__res">{resolution}</span>
        <span class="video-card__dur">{formatDuration(duration)}</span>
      </div>
      {featured && <span class="video-card__featured-label">Featured</span>}
    </div>
  </a>

  <div class="video-card__body">
    <div class="video-card__meta">
      <a href={`/kategorie/${category}`} class="tag video-card__cat">
        {categoryLabels[category] ?? category}
      </a>
    </div>
    <h3 class="video-card__title">
      <a href={`/video/${slug}`}>{title}</a>
    </h3>
    {description && (
      <p class="video-card__desc">{description.slice(0, 90)}{description.length > 90 ? '…' : ''}</p>
    )}
    <div class="video-card__footer">
      <span class="video-card__price">ab <strong>€{price.web}</strong></span>
      <a href={`/video/${slug}`} class="btn btn-primary video-card__btn">Lizenzieren</a>
    </div>
  </div>
</article>

<style>
.video-card { display: flex; flex-direction: column; }

/* Media */
.video-card__media-link { display: block; }
.video-card__media {
  position: relative;
  aspect-ratio: 16 / 9;
  background: var(--color-bg-3);
  overflow: hidden;
}
.video-card__thumb {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}
.video-card:hover .video-card__thumb { transform: scale(1.04); }

/* Placeholder */
.video-card__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-faint);
  background: linear-gradient(135deg, var(--color-bg-3) 0%, var(--color-bg-card) 100%);
}

/* Overlay */
.video-card__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity var(--transition);
}
.video-card:hover .video-card__overlay { opacity: 1; }
.video-card__play {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: rgba(232, 23, 60, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  transform: scale(0.85);
  transition: transform var(--transition);
}
.video-card:hover .video-card__play { transform: scale(1); }

/* Badges */
.video-card__badges {
  position: absolute;
  bottom: 8px;
  left: 8px;
  display: flex;
  gap: 6px;
}
.video-card__res, .video-card__dur {
  background: rgba(0,0,0,0.75);
  color: #e0e0e0;
  font-size: 0.7rem;
  font-weight: 600;
  padding: 2px 7px;
  border-radius: 4px;
  letter-spacing: 0.04em;
}

.video-card__featured-label {
  position: absolute;
  top: 8px;
  right: 8px;
  background: var(--color-accent);
  color: #fff;
  font-size: 0.7rem;
  font-weight: 700;
  padding: 3px 8px;
  border-radius: 4px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

/* Body */
.video-card__body {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
}
.video-card__meta { display: flex; gap: 8px; align-items: center; }
.video-card__cat { font-size: 0.75rem; }

.video-card__title {
  font-size: 1rem;
  font-weight: 600;
  line-height: 1.35;
}
.video-card__title a { color: var(--color-text); }
.video-card__title a:hover { color: var(--color-accent); }

.video-card__desc {
  font-size: 0.85rem;
  color: var(--color-text-muted);
  line-height: 1.5;
}

.video-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
  padding-top: 12px;
  border-top: 1px solid var(--color-border);
}
.video-card__price { font-size: 0.875rem; color: var(--color-text-muted); }
.video-card__price strong { color: var(--color-text); font-weight: 700; }
.video-card__btn { padding: 8px 16px; font-size: 0.8125rem; }
</style>
