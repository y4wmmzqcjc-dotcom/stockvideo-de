---
const categories = [
  { slug: 'business',    label: 'Business',   emoji: '💼', count: '120+' },
  { slug: 'natur',       label: 'Natur',      emoji: '🌿', count: '180+' },
  { slug: 'lifestyle',   label: 'Lifestyle',  emoji: '✨', count: '95+' },
  { slug: 'architektur', label: 'Architektur',emoji: '🏛️', count: '60+' },
  { slug: 'technologie', label: 'Technologie',emoji: '💻', count: '75+' },
  { slug: 'sport',       label: 'Sport',      emoji: '⚡', count: '50+' },
];
---

<section class="category-strip section-sm" aria-label="Video-Kategorien">
  <div class="container">
    <div class="category-strip__header">
      <h2 class="category-strip__title">Nach Kategorie stöbern</h2>
      <a href="/kategorie" class="btn btn-ghost">Alle anzeigen →</a>
    </div>

    <div class="category-strip__grid" role="list">
      {categories.map(cat => (
        <a
          href={`/kategorie/${cat.slug}`}
          class="category-card"
          role="listitem"
          aria-label={`${cat.label} — ${cat.count} Videos`}
        >
          <div class="category-card__icon" aria-hidden="true">{cat.emoji}</div>
          <div class="category-card__info">
            <span class="category-card__label">{cat.label}</span>
            <span class="category-card__count">{cat.count} Videos</span>
          </div>
          <svg class="category-card__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
.category-strip__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
  flex-wrap: wrap;
  gap: 12px;
}
.category-strip__title {
  font-size: 1.25rem;
}

.category-strip__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 12px;
}

.category-card {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  text-decoration: none;
  transition: all var(--transition);
  group: true;
}
.category-card:hover {
  border-color: var(--color-accent);
  background: var(--color-accent-soft);
  transform: translateY(-2px);
}
.category-card:hover .category-card__arrow {
  color: var(--color-accent);
  transform: translateX(2px);
}

.category-card__icon {
  font-size: 1.5rem;
  line-height: 1;
  flex-shrink: 0;
}
.category-card__info {
  flex: 1;
  min-width: 0;
}
.category-card__label {
  display: block;
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--color-text);
}
.category-card__count {
  display: block;
  font-size: 0.8125rem;
  color: var(--color-text-muted);
  margin-top: 1px;
}
.category-card__arrow {
  color: var(--color-text-faint);
  flex-shrink: 0;
  transition: all var(--transition);
}

@media (max-width: 640px) {
  .category-strip__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
</style>
