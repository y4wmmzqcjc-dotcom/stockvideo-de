---
import categories from '../data/categories.json';

function getIconSVG(iconName: string) {
  const icons: Record<string, string> = {
    film: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="2" y1="7" x2="22" y2="7"/><line x1="2" y1="17" x2="22" y2="17"/></svg>',
    map: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>',
    shield: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
    download: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>',
    tag: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><circle cx="8" cy="8" r="1.5"/></svg>',
    lock: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>'
  };
  return icons[iconName] || icons.film;
}
---

<section class="category-section section container">
  <div class="section-header">
    <h2>Nach Kategorien durchsuchen</h2>
    <p>Entdecke Videos in verschiedenen Kategorien</p>
  </div>

  <div class="category-strip">
    {categories.map((category) => (
      <a href={`/kategorie/${category.slug}`} class="category-card">
        <div class="category-card__icon">
          <Fragment set:html={getIconSVG(category.icon)} />
        </div>
        <h3 class="category-card__label">{category.label}</h3>
        <p class="category-card__description">{category.description}</p>
      </a>
    ))}
  </div>
</section>

<style>
  .category-section {
    margin: 2rem 0;
  }

  .section-header {
    text-align: center;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 2rem;
  }

  .category-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    overflow-x: auto;
    padding: 0.5rem 0;
    scroll-behavior: smooth;
  }

  .category-card {
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
    transition: all var(--transition);
    text-align: center;
  }

  .category-card:hover {
    border-color: var(--color-accent);
    background-color: var(--color-bg-3);
    box-shadow: 0 8px 24px rgba(20, 115, 230, 0.15);
    transform: translateY(-4px);
  }

  .category-card__icon {
    width: 56px;
    height: 56px;
    margin: 0 auto;
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .category-card__icon svg {
    width: 100%;
    height: 100%;
  }

  .category-card__label {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0;
    color: var(--color-text);
  }

  .category-card__description {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .category-strip {
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1rem;
    }

    .category-card {
      padding: 1.25rem;
    }

    .category-card__icon {
      width: 48px;
      height: 48px;
    }

    .category-card__label {
      font-size: 1rem;
    }

    .category-card__description {
      font-size: 0.8125rem;
    }
  }

  @media (max-width: 480px) {
    .category-section {
      margin: 1rem 0;
    }

    .section-header {
      margin-bottom: 1.5rem;
    }

    .category-strip {
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 0.75rem;
    }

    .category-card {
      padding: 1rem;
      gap: 0.75rem;
    }

    .category-card__icon {
      width: 40px;
      height: 40px;
    }

    .category-card__label {
      font-size: 0.9375rem;
    }

    .category-card__description {
      display: none;
    }
  }
</style>
