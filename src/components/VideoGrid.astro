---
import videos from '../../public/data/videos.json';
import categoriesData from '../../public/data/categories.json';
---
<section>
  <div class="video-grid" id="videoGrid"></div>
  <div class="no-results" id="noResults">
    <div class="no-results-icon">&#x2315;</div>
    <h3>Keine Ergebnisse</h3>
    <p>Versuch einen anderen Suchbegriff oder wähle eine Kategorie.</p>
  </div>
</section>

<script define:vars={{ videos, categoriesData }}>
// Build catLabels dynamically from categories.json
const catLabels = { all: "Alle Videos" };
(categoriesData || []).forEach(c => { if (c.dataCat || c.slug) catLabels[c.dataCat || c.slug] = c.label; });

// Initialstate aus URL-Query uebernehmen (?res=4k|hd, ?sort=neu|price-asc|price-desc|relevant, ?cat=...)
// Falls die Params fehlen oder ungueltig sind, greifen die Defaults.
const params = new URLSearchParams(window.location.search);
const ALLOWED_RES  = { "4k":"4k", "hd":"hd", "all":"all" };
const ALLOWED_SORT = { "relevant":"relevant", "neu":"neu", "price-asc":"price-asc", "price-desc":"price-desc" };
const initRes  = ALLOWED_RES[(params.get("res") || "all").toLowerCase()] || "all";
const initSort = ALLOWED_SORT[(params.get("sort") || "relevant").toLowerCase()] || "relevant";
const initCat  = params.get("cat") || "all";

let state = { search:"", cat:initCat, res:initRes, sort:initSort };

// Toolbar-UI an Initialstate angleichen (Button-Label, Select-Value, aktive Kategorie)
(function syncToolbarUI(){
  const rb = document.getElementById("resFilterBtn");
  if (rb) {
    rb.dataset.state = state.res;
    rb.textContent = state.res === "all" ? "Aufl\u00f6sung" : state.res === "4k" ? "Nur 4K" : "Nur HD";
    rb.classList.toggle("active", state.res !== "all");
  }
  const ss = document.getElementById("sortSelect");
  if (ss) ss.value = state.sort;
  if (state.cat && state.cat !== "all") {
    const target = document.querySelector('.cat-chip[data-cat="' + state.cat.replace(/"/g,'') + '"]');
    if (target) {
      document.querySelectorAll('.cat-chip').forEach(b => b.classList.remove('active'));
      target.classList.add('active');
    }
  }
})();

function render() {
  let list = videos.filter(v => {
    const mc = state.cat === "all" || v.category === state.cat;
    const q = state.search.toLowerCase().trim();
      const hay = [v.title,v.description,v.videoId,v.slug,(v.tags||[]).join(' '),v.category].filter(Boolean).join(' ').toLowerCase();
      const ms = !q || hay.includes(q);
    const mr = state.res === "all" || (state.res === "4k" && v.resolution === "4K") || (state.res === "hd" && v.resolution === "HD");
    return mc && ms && mr;
  });

  const priceOf = v => Number(v.price ?? (v.prices && v.prices.web) ?? 0) || 0;
  if (state.sort === "price-asc")  list.sort((a,b) => priceOf(a) - priceOf(b));
  if (state.sort === "price-desc") list.sort((a,b) => priceOf(b) - priceOf(a));
  // "neu" = nach video.id (Unix-ms-Timestamp) absteigend. Fallback fuer nicht-numerische IDs: string compare desc.
  if (state.sort === "neu") list.sort((a,b) => {
    const na = Number(a.id), nb = Number(b.id);
    if (Number.isFinite(na) && Number.isFinite(nb)) return nb - na;
    return String(b.id||'').localeCompare(String(a.id||''));
  });

  const grid = document.getElementById("videoGrid");
  const noRes = document.getElementById("noResults");
  const countEl = document.getElementById("resultCount");

  const catText = state.cat !== "all" ? ` in \u201E${catLabels[state.cat]}\u201C` : "";
  countEl.textContent = `${list.length} Ergebnis${list.length !== 1 ? "se" : ""}${catText}`;

  if (list.length === 0) {
    grid.innerHTML = "";
    noRes.classList.add("visible");
    return;
  }
  noRes.classList.remove("visible");

  grid.innerHTML = list.map(v => `
    <a href="/video/${v.slug}/" style="text-decoration:none;color:inherit;display:block"><div class="video-card">
      <div class="video-thumb">
        ${v.thumbnail ? '<img src="' + v.thumbnail + '" style="width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0;z-index:1;" >' : '<div class="thumb-bg" style="background:' + v.gradient + '"></div>'}${v.r2Hover ? '<video class="hov-prev" muted playsinline preload="none" style="visibility:hidden;position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:2" data-src="https://pub-03757a2d41d2442dabdeaa0a62f5d1ad.r2.dev/' + v.r2Hover + '" style="width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0;z-index:2;opacity:0;transition: none;"></video>' : ''}
        <div class="thumb-texture" style="background:
          radial-gradient(circle at 25% 35%,rgba(255,255,255,0.06) 0%,transparent 45%),
          radial-gradient(circle at 75% 65%,rgba(255,255,255,0.04) 0%,transparent 35%),
          radial-gradient(circle at 50% 80%,rgba(255,255,255,0.02) 0%,transparent 50%)
        "></div>
        <span class="res-badge ${v.resolution === '4K' ? 'res-4k' : 'res-hd'}">${v.resolution}</span>
        <span class="dur-badge">${v.duration} sek</span>
      </div>
      <div class="card-info">
        <span class="card-title">${v.title}</span>
        <span class="card-price">${v.price || (v.prices && v.prices.web) || 0} \u20ac</span>
      </div>
    </div></a>
  `).join("");
}

document.getElementById("searchInput")?.addEventListener("input", e => {
  state.search = e.target.value;
  render();
});

document.getElementById("catStrip")?.addEventListener("click", e => {
  const btn = e.target.closest(".cat-chip");
  if (!btn) return;
  state.cat = btn.dataset.cat;
  document.querySelectorAll(".cat-chip").forEach(b => b.classList.remove("active"));
  btn.classList.add("active");
  render();
});

document.getElementById("resFilterBtn")?.addEventListener("click", e => {
  const btn = e.target;
  const cycle = { all:"4k", "4k":"hd", hd:"all" };
  state.res = cycle[state.res];
  btn.textContent = state.res === "all" ? "Auflösung" : state.res === "4k" ? "Nur 4K" : "Nur HD";
  btn.classList.toggle("active", state.res !== "all");
  render();
});

document.getElementById("sortSelect")?.addEventListener("change", e => {
  state.sort = e.target.value;
  render();
});

render();
var _grid = document.getElementById('videoGrid');
if(_grid){
  // Hidden canvas for brightness sampling
  var _bcanv=document.createElement('canvas');_bcanv.width=32;_bcanv.height=18;var _bctx=_bcanv.getContext('2d',{willReadFrequently:true});
  var BRIGHTNESS_MIN=40; // average channel value (0-255). black watermark frames score very low
  var sampleBright=function(v){try{_bctx.drawImage(v,0,0,32,18);var d=_bctx.getImageData(0,0,32,18).data;var s=0;for(var i=0;i<d.length;i+=4)s+=d[i]+d[i+1]+d[i+2];return s/(d.length/4*3);}catch(e){return 999;}};
  var _setupVideo=function(v){
    if(v._setup)return;v._setup=1;
    v.style.visibility='hidden';
    v.muted=true;v.playsInline=true;v.removeAttribute('loop');
    v.addEventListener('ended',function(){try{v.currentTime=0.05;}catch(e){}var p=v.play();if(p&&p.catch)p.catch(function(){});});
  };
  var _enter=function(card){
    var v=card.querySelector('video.hov-prev');if(!v)return;
    _setupVideo(v);
    var token=(card._tk=(card._tk||0)+1);
    v.style.visibility='hidden';
    if(!v.src&&v.dataset.src){v.src=v.dataset.src;try{v.load();}catch(e){}}
    var begin=function(){
      if(card._tk!==token)return;
      var p=v.play();if(p&&p.catch)p.catch(function(){});
      var revealed=false;var lastT=-1;var stallCount=0;var rafId=null;
      var reveal=function(){if(revealed||card._tk!==token)return;revealed=true;v.style.visibility='visible';};
      var tick=function(){
        if(card._tk!==token)return;
        // Stall detection: if currentTime hasn't advanced and not paused, kick play
        if(!v.paused){
          if(v.currentTime===lastT){stallCount++;if(stallCount>10){stallCount=0;try{v.currentTime+=0.05;}catch(e){}var pp=v.play();if(pp&&pp.catch)pp.catch(function(){});}}else{stallCount=0;lastT=v.currentTime;}
        }
        if(!revealed){
          if(v.readyState>=2){
            var b=sampleBright(v);
            if(b>=BRIGHTNESS_MIN){reveal();}
            else if(v.currentTime< (v.duration||9)-0.2){
              // Skip past dark frame
              try{v.currentTime=Math.min((v.duration||9)-0.2,v.currentTime+0.2);}catch(e){}
            }
          }
        }
        rafId=requestAnimationFrame(tick);
      };
      rafId=requestAnimationFrame(tick);
      card._stop=function(){if(rafId)cancelAnimationFrame(rafId);rafId=null;};
      // Hard fallback: reveal after 1.2s no matter what so user is never stuck on hidden
      setTimeout(function(){if(card._tk===token)reveal();},1200);
    };
    if(v.readyState>=1)begin();
    else v.addEventListener('loadedmetadata',begin,{once:true});
  };
  var _leave=function(card){
    var v=card.querySelector('video.hov-prev');if(!v)return;
    card._tk=(card._tk||0)+1;
    if(card._stop){card._stop();card._stop=null;}
    try{v.pause();}catch(e){}
    v.style.visibility='hidden';
    try{v.currentTime=0.05;}catch(e){}
  };
  _grid.addEventListener('mouseover',function(e){var c=e.target.closest&&e.target.closest('.video-card');if(!c)return;if(c._hovering)return;c._hovering=1;_enter(c);});
  _grid.addEventListener('mouseout',function(e){var c=e.target.closest&&e.target.closest('.video-card');if(!c)return;var to=e.relatedTarget;if(to&&c.contains(to))return;c._hovering=0;_leave(c);});
  var _all=function(){_grid.querySelectorAll('video.hov-prev').forEach(_setupVideo);};
  _all();
  new MutationObserver(_all).observe(_grid,{childList:true,subtree:true});
}
</script>
