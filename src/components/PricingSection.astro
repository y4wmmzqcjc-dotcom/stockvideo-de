---
import config from '../../public/data/config.json';
---
<section class="pricing">
  <h2>Faire Preise, transparent</h2>
  <p>Einzelkauf oder spare mit Videopaketen. du entscheidest.</p>
  <div class="pricing-grid">
    {config.pricing.map(p => (
      <div class={`price-card${p.featured ? ' featured' : ''}`}>
        <div class="price-label">{p.label}</div>
        <div class="price-res">{p.res}</div>
        <div class="price-amount">{p.price} &euro;</div>
        <div class="price-vat">inkl. 19&nbsp;% MwSt.</div>
        <div class="price-desc">{p.desc}</div>
      </div>
    ))}
  </div>
  <p class="pricing-vat-note">Alle Preise inkl. 19&nbsp;% gesetzl. MwSt. Rechnung mit ausgewiesener Umsatzsteuer nach § 14 UStG wird direkt nach dem Kauf per E-Mail zugestellt.</p>
</section>

<style>
  .price-vat {
    font-size: 12px;
    color: var(--text-muted, #8aa);
    margin-top: -4px;
    margin-bottom: 8px;
  }
  .pricing-vat-note {
    max-width: 760px;
    margin: 28px auto 0;
    text-align: center;
    font-size: 13px;
    color: var(--text-muted, #8aa);
    line-height: 1.55;
  }
</style>
