---
interface Props {
  text?: string;
  linkText?: string;
  linkHref?: string;
}

const {
  text = '🎬 Neu: 4K-Drohnenaufnahmen jetzt verfügbar',
  linkText = 'Jetzt entdecken',
  linkHref = '/kategorie/natur',
} = Astro.props;
---

<div class="promo-bar">
  <div class="container">
    <span class="promo-bar__text">{text}</span>
    {linkText && (
      <a href={linkHref} class="promo-bar__link">
        {linkText} →
      </a>
    )}
    <button class="promo-bar__close" aria-label="Schließen" id="promo-close">✕</button>
  </div>
</div>

<style>
.promo-bar {
  background: linear-gradient(90deg, #1a0a0e 0%, #2a0d18 50%, #1a0a0e 100%);
  border-bottom: 1px solid rgba(232, 23, 60, 0.25);
  padding: 10px 0;
  position: relative;
  z-index: 100;
}
.promo-bar .container {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  flex-wrap: wrap;
}
.promo-bar__text {
  font-size: 0.875rem;
  color: #e0c0c8;
}
.promo-bar__link {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-accent);
  white-space: nowrap;
}
.promo-bar__link:hover { text-decoration: underline; }
.promo-bar__close {
  position: absolute;
  right: 16px;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  color: #777;
  cursor: pointer;
  font-size: 0.875rem;
  padding: 4px 8px;
  transition: color 0.2s;
}
.promo-bar__close:hover { color: #ccc; }
</style>

<script>
  document.getElementById('promo-close')?.addEventListener('click', function() {
    const bar = this.closest('.promo-bar') as HTMLElement;
    if (bar) bar.style.display = 'none';
  });
</script>
