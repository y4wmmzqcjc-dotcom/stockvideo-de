---
const features = [
  {
    icon: '🎬',
    title: '4K Ultra HD Qualität',
    desc: 'Alle Videos in professioneller 4K-Auflösung — scharf, detailreich und kinoreif.',
  },
  {
    icon: '🇩🇪',
    title: '100% Deutscher Content',
    desc: 'Aufnahmen aus Deutschland und dem deutschsprachigen Raum. Authentisch und lokal relevant.',
  },
  {
    icon: '📄',
    title: 'Klare Lizenzierung',
    desc: 'Verständliche Lizenzbedingungen ohne Kleingedrucktes. Web, Broadcast und Extended Lizenz.',
  },
  {
    icon: '⚡',
    title: 'Sofort-Download',
    desc: 'Nach dem Kauf steht der Download sofort bereit — ohne Wartezeit oder Freigabeprozess.',
  },
  {
    icon: '💰',
    title: 'Faire Preise',
    desc: 'Günstige Einstiegspreise für Web-Nutzung, skalierbar je nach Reichweite und Verwendungszweck.',
  },
  {
    icon: '🔒',
    title: 'Sichere Zahlung',
    desc: 'Zahlung via Stripe — verschlüsselt und sicher. Kreditkarte, SEPA und weitere Optionen.',
  },
];
---

<section class="features section" aria-labelledby="features-title">
  <div class="container">
    <div class="section-header">
      <h2 id="features-title">Warum stockvideo.de?</h2>
      <p>Wir machen die Lizenzierung professioneller Stock-Videos so einfach wie möglich.</p>
    </div>

    <div class="features__grid" role="list">
      {features.map(f => (
        <div class="feature-card" role="listitem">
          <div class="feature-card__icon" aria-hidden="true">{f.icon}</div>
          <div class="feature-card__content">
            <h3 class="feature-card__title">{f.title}</h3>
            <p class="feature-card__desc">{f.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.features { background: var(--color-bg-2); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }

.features__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 20px;
}

.feature-card {
  display: flex;
  gap: 16px;
  padding: 24px;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  transition: border-color var(--transition), transform var(--transition);
}
.feature-card:hover {
  border-color: var(--color-border-light);
  transform: translateY(-2px);
}

.feature-card__icon {
  font-size: 1.75rem;
  line-height: 1;
  flex-shrink: 0;
  margin-top: 2px;
}

.feature-card__title {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 6px;
}
.feature-card__desc {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  line-height: 1.6;
}

@media (max-width: 640px) {
  .features__grid { grid-template-columns: 1fr; }
}
</style>
