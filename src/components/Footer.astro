---
const year = new Date().getFullYear();

const links = {
  Videos: [
    { href: '/kategorie/business',    label: 'Business Videos' },
    { href: '/kategorie/natur',       label: 'Natur & Landschaft' },
    { href: '/kategorie/lifestyle',   label: 'Lifestyle' },
    { href: '/kategorie/architektur', label: 'Architektur' },
    { href: '/kategorie/technologie', label: 'Technologie' },
  ],
  Service: [
    { href: '/preise',     label: 'Preise & Lizenzen' },
    { href: '/lizenzen',   label: 'Lizenzübersicht' },
    { href: '/ueber-uns',  label: 'Über uns' },
    { href: '/kontakt',    label: 'Kontakt' },
    { href: '/blog',       label: 'Blog' },
  ],
  Rechtliches: [
    { href: '/impressum',    label: 'Impressum' },
    { href: '/datenschutz',  label: 'Datenschutz' },
    { href: '/agb',          label: 'AGB' },
  ],
};
---

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer__main">
      <!-- Brand -->
      <div class="footer__brand">
        <a href="/" class="footer__logo" aria-label="stockvideo.de – Startseite">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
            <rect width="28" height="28" rx="6" fill="var(--color-accent)"/>
            <path d="M9 8.5v11l10-5.5L9 8.5z" fill="white"/>
          </svg>
          <span>stockvideo<span style="color: var(--color-accent)">.de</span></span>
        </a>
        <p class="footer__tagline">
          Hochwertige deutsche Stock-Videos. Lizenzfrei, sofort verfügbar, fair bepreist.
        </p>
        <div class="footer__trust">
          <span class="footer__trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            SSL-gesichert
          </span>
          <span class="footer__trust-item">🇩🇪 Hosting in Deutschland</span>
          <span class="footer__trust-item">DSGVO-konform</span>
        </div>
      </div>

      <!-- Nav columns -->
      {Object.entries(links).map(([heading, items]) => (
        <nav class="footer__nav" aria-label={heading}>
          <h3 class="footer__nav-title">{heading}</h3>
          <ul>
            {items.map(item => (
              <li><a href={item.href} class="footer__nav-link">{item.label}</a></li>
            ))}
          </ul>
        </nav>
      ))}
    </div>

    <hr class="divider" />

    <div class="footer__bottom">
      <p class="footer__copy">
        © {year} stockvideo.de · Alle Rechte vorbehalten
      </p>
      <p class="footer__copy footer__copy--right">
        Made with ♥ in Deutschland
      </p>
    </div>
  </div>
</footer>

<style>
.footer {
  background: var(--color-bg-2);
  border-top: 1px solid var(--color-border);
  padding: 64px 0 32px;
  margin-top: auto;
}

.footer__main {
  display: grid;
  grid-template-columns: 1.5fr repeat(3, 1fr);
  gap: 48px;
  margin-bottom: 48px;
}

/* Brand */
.footer__logo {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 12px;
}
.footer__logo:hover { color: var(--color-text); }

.footer__tagline {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  line-height: 1.6;
  max-width: 260px;
  margin-bottom: 16px;
}

.footer__trust {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}
.footer__trust-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 0.775rem;
  color: var(--color-text-faint);
}

/* Nav */
.footer__nav-title {
  font-size: 0.8125rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-text-muted);
  margin-bottom: 16px;
}
.footer__nav ul { display: flex; flex-direction: column; gap: 10px; }
.footer__nav-link {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  transition: color var(--transition);
}
.footer__nav-link:hover { color: var(--color-text); }

/* Bottom */
.footer__bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 24px;
  flex-wrap: wrap;
  gap: 8px;
}
.footer__copy {
  font-size: 0.8125rem;
  color: var(--color-text-faint);
}

@media (max-width: 960px) {
  .footer__main { grid-template-columns: 1fr 1fr; gap: 32px; }
  .footer__brand { grid-column: 1 / -1; }
}
@media (max-width: 560px) {
  .footer__main { grid-template-columns: 1fr; }
  .footer__bottom { flex-direction: column; align-items: flex-start; }
}
</style>
