---
import config from '../data/config.json';

const { hero } = config;
---

<section class="hero">
  <div class="hero__background">
    <div class="hero__grid"></div>
  </div>
  
  <div class="hero__content container">
    <div class="hero__badge">
      <span class="badge-accent">{hero.badge}</span>
    </div>

    <h1 class="hero__headline">
      <span class="gradient-text">{hero.headline}</span>
    </h1>

    <p class="hero__subline">{hero.subline}</p>

    <form class="hero__search" action="/suche">
      <input
        type="search"
        name="q"
        placeholder={hero.searchPlaceholder}
        class="hero__search-input"
      />
      <button type="submit" class="btn btn-primary">Suchen</button>
    </form>

    <div class="hero__tags">
      <span class="hero__tags-label">Beliebte Tags:</span>
      <div class="hero__tags-list">
        {hero.popularTags.map((tag) => (
          <a href={`/suche?q=${tag}`} class="tag">{tag}</a>
        ))}
      </div>
    </div>

    <div class="hero__stats">
      {hero.stats.map((stat) => (
        <div class="hero__stat-card">
          <div class="hero__stat-number">{stat.number}</div>
          <div class="hero__stat-label">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 8rem 1.5rem;
    overflow: hidden;
  }

  .hero__background {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 0;
  }

  .hero__grid {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image:
      linear-gradient(
        0deg,
        transparent 24%,
        rgba(20, 115, 230, 0.05) 25%,
        rgba(20, 115, 230, 0.05) 26%,
        transparent 27%,
        transparent 74%,
        rgba(20, 115, 230, 0.05) 75%,
        rgba(20, 115, 230, 0.05) 76%,
        transparent 77%,
        transparent
      ),
      linear-gradient(
        90deg,
        transparent 24%,
        rgba(20, 115, 230, 0.05) 25%,
        rgba(20, 115, 230, 0.05) 26%,
        transparent 27%,
        transparent 74%,
        rgba(20, 115, 230, 0.05) 75%,
        rgba(20, 115, 230, 0.05) 76%,
        transparent 77%,
        transparent
      );
    background-size: 50px 50px;
  }

  .hero__background::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(20, 115, 230, 0.1) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(40px);
  }

  .hero__background::after {
    content: '';
    position: absolute;
    bottom: -30%;
    left: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(20, 115, 230, 0.08) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(40px);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .hero__badge {
    display: flex;
    justify-content: center;
  }

  .hero__headline {
    margin: 0;
    line-height: 1.1;
  }

  .hero__subline {
    color: var(--color-text-muted);
    font-size: 1.25rem;
    margin: 0;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero__search {
    display: flex;
    gap: 0.5rem;
    max-width: 600px;
    margin: 1rem auto 0;
  }

  .hero__search-input {
    flex: 1;
    min-height: 48px;
    font-size: 1rem;
  }

  .hero__search .btn {
    min-height: 48px;
    padding: 0.75rem 2rem;
  }

  .hero__tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 1rem;
  }

  .hero__tags-label {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }

  .hero__tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  .hero__tags .tag {
    font-size: 0.875rem;
  }

  .hero__stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .hero__stat-card {
    background-color: rgba(20, 115, 230, 0.05);
    border: 1px solid rgba(20, 115, 230, 0.1);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    text-align: center;
  }

  .hero__stat-number {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .hero__stat-label {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 4rem 1.5rem;
    }

    .hero__subline {
      font-size: 1.125rem;
    }

    .hero__search {
      flex-direction: column;
    }

    .hero__tags {
      margin-top: 0.75rem;
      gap: 0.75rem;
    }

    .hero__stats {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      margin-top: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 2.5rem 1rem;
    }

    .hero__subline {
      font-size: 1rem;
    }

    .hero__tags {
      flex-direction: column;
      gap: 0.5rem;
    }

    .hero__tags-label {
      width: 100%;
    }

    .hero__stats {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .hero__stat-number {
      font-size: 1.5rem;
    }
  }
</style>
