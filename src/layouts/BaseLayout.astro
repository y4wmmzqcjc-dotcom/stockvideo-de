---
import '../styles/global.css';
import config from '../data/config.json';

interface Props {
  title?: string;
  description?: string;
}

const { title = config.siteName, description = config.siteDescription } = Astro.props;
const pageTitle = title === config.siteName ? `${config.siteName} — Lizenzfreie Stock Videos in 4K & HD` : `${title} — ${config.siteName}`;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{pageTitle}</title>
  <meta name="description" content={description}>
  <meta name="keywords" content="stock video, stock footage, lizenzfreie videos, videoclips kaufen, 4K video, stock video kaufen, stock footage deutsch">
  <meta property="og:title" content={pageTitle}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={config.siteUrl}>
  <link rel="canonical" href={new URL(Astro.url.pathname, config.siteUrl).href}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "stockvideo.de",
    "url": "https://stockvideo.de",
    "contactPoint": {
      "@type": "ContactPoint",
      "email": config.contact.email,
      "telephone": `+49 ${config.contact.phone}`
    }
  })} />
</head>
<body>
  <slot />
</body>
</html>
