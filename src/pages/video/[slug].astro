---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Topbar from '../../components/Topbar.astro';
import Footer from '../../components/Footer.astro';
import videos from '../../../public/data/videos.json';
import categories from '../../../public/data/categories.json';

export function getStaticPaths() {
  return videos.map(v => ({ params: { slug: v.slug } }));
}

const { slug } = Astro.params;
const video = videos.find(v => v.slug === slug);
if (!video) return Astro.redirect('/');
const cat = categories.find(c => c.dataCat === video.category);
const r2Base = 'https://pub-03757a2d41d2442dabdeaa0a62f5d1ad.r2.dev';

const previewUrl = video.r2Preview ? r2Base + '/' + video.r2Preview : '';
const videoUrl = previewUrl || (video.r2Key ? r2Base + '/' + video.r2Key : '');
const price = video.price || (video.prices && video.prices.web) || 5;
// Preis ist Brutto inkl. 19% MwSt. Aufschluesselung fuer transparente Anzeige.
const vatRate = 0.19;
const priceNet = price / (1 + vatRate);
const priceVat = price - priceNet;
const fmt = (n: number) => n.toFixed(2).replace('.', ',');

// Ähnliche Videos: Clips mit mindestens einem gemeinsamen Tag, sortiert nach Überlappungsgrad
const ownTags = (video.tags || []).map(t => String(t).toLowerCase());
const similar = videos
  .filter(v => v.slug !== video.slug)
  .map(v => {
    const theirTags = (v.tags || []).map(t => String(t).toLowerCase());
    const overlap = theirTags.filter(t => ownTags.includes(t)).length;
    return { v, overlap };
  })
  .filter(x => x.overlap > 0)
  .sort((a,b) => b.overlap - a.overlap)
  .slice(0, 8)
  .map(x => x.v);
---

<BaseLayout title={video.title} description={video.description}>
  <Topbar />
  <div class="page-content" style="max-width:1200px;">
    <div style="margin-bottom:12px;">
      <a href="/" style="color:var(--accent);font-size:14px;">← Zurück zur Übersicht</a>
      {cat && <span style="color:#666;font-size:14px;margin-left:12px;">/ <a href={`/kategorie/${video.category}`} style="color:var(--accent);">{cat.label}</a></span>}
    </div>

    {/* Row 1: Video + Preisbox (gleiche Höhe) */}
    <div class="video-top-row">
      <div class="video-col">
        <div id="videoContainer" style="aspect-ratio:16/9;border-radius:10px;overflow:hidden;position:relative;cursor:pointer;background:#000;">
          {videoUrl && (
            <video id="videoPlayer" style="width:100%;height:100%;object-fit:cover;display:none;"
              controls controlsList="nodownload" disablePictureInPicture
              oncontextmenu="return false" preload="metadata" poster={video.thumbnail}><source src={videoUrl} type="video/mp4" />
            </video>
          )}
          <div id="videoPoster" style={`position:absolute;inset:0;background:#000 center/cover no-repeat url(${video.thumbnail});`}>
            <div style="position:absolute;inset:0;background:radial-gradient(circle at 25% 35%,rgba(255,255,255,0.06) 0%,transparent 45%),radial-gradient(circle at 75% 65%,rgba(255,255,255,0.04) 0%,transparent 35%);opacity:0.35;"></div>
            <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
              <div id="playBtn" style="width:72px;height:72px;border-radius:50%;background:rgba(255,255,255,0.95);display:flex;align-items:center;justify-content:center;box-shadow:0 4px 24px rgba(0,0,0,0.4);transition:transform 0.2s;">
                <svg width="24" height="24" viewBox="0 0 16 16" fill="#1b1b1b"><path d="M4 2l10 6-10 6z"/></svg>
              </div>
            </div>
          </div>
          <div class="detail-badges">
            <span class={`res-badge ${video.resolution === '4K' ? 'res-4k' : 'res-hd'}`}>{video.resolution}</span>
            <span class="dur-badge">{video.duration} sek</span>
            {video.r2Preview && <span class="preview-badge">VORSCHAU</span>}
          </div>
        </div>
      </div>

      <div class="price-col">
        <div class="price-box">
          <div>
            <div style="font-size:clamp(28px,3.5vw,40px);font-weight:700;color:#4ade80;line-height:1;margin-bottom:6px;">{fmt(price)} €</div>
            <div style="color:#8a9a8a;font-size:12px;margin-bottom:10px;">Bruttopreis inkl. 19 % MwSt.</div>
            <div style="display:flex;gap:14px;flex-wrap:wrap;font-size:12px;color:#b5c5b5;">
              <span>Netto: <strong style="color:#d1e5d1;">{fmt(priceNet)} €</strong></span>
              <span style="color:#4a5a4a;">·</span>
              <span>MwSt. 19 %: <strong style="color:#d1e5d1;">{fmt(priceVat)} €</strong></span>
            </div>
          </div>

          <ul class="price-benefits">
            <li>Einmalige Zahlung · sofortiger Download</li>
            <li>Lizenz inklusive · kommerzielle Nutzung</li>
            <li>Originaldatei in {video.resolution}</li>
            <li>MwSt.-Rechnung nach Kauf</li>
          </ul>

          <div>
            <button id="buyBtn" class="btn-primary" style="padding:14px 28px;font-size:16px;font-weight:700;border-radius:8px;cursor:pointer;width:100%;">
              Jetzt kaufen
            </button>
            {video.r2Preview && (
              <button id="dlPreviewBtn" data-key={video.r2Preview} data-name={`stockvideo-${video.slug}-preview${video.r2Preview && video.r2Preview.endsWith('.webm') ? '.webm' : '.mp4'}`} style="margin-top:10px;padding:10px 20px;border-radius:6px;font-size:13px;color:#cfd8cf;background:transparent;border:1px solid #2d4a2d;cursor:pointer;width:100%;">
                ⬇ Vorschau (480p) herunterladen
              </button>
            )}
            <div id="buySpinner" style="display:none;margin-top:10px;color:#999;text-align:center;font-size:13px;">Weiterleitung zu Mollie…</div>
            <div id="buyError" style="display:none;margin-top:10px;color:#ef4444;font-size:13px;text-align:center;"></div>
          </div>
        </div>
      </div>
    </div>

    {/* Row 2: Titel, Beschreibung, Specs (linke Spalte entlang) */}
    <div class="video-meta">
      <h1 style="font-size:clamp(22px,2.6vw,30px);margin:0 0 10px;">{video.title}</h1>
      {video.description && <p style="color:#bbb;line-height:1.6;margin:0 0 18px;">{video.description}</p>}

      <div style="display:flex;gap:8px;flex-wrap:wrap;margin:0 0 4px;">
        <span style="background:#2a2a2a;padding:8px 16px;border-radius:6px;font-size:13px;color:#ccc;">Auflösung: {video.resolution}</span>
        <span style="background:#2a2a2a;padding:8px 16px;border-radius:6px;font-size:13px;color:#ccc;">Dauer: {video.duration} sek</span>
        <span style="background:#2a2a2a;padding:8px 16px;border-radius:6px;font-size:13px;color:#ccc;">{video.fps} FPS</span>
        <span style="background:#2a2a2a;padding:8px 16px;border-radius:6px;font-size:13px;color:#ccc;">MP4 / MOV</span>
        {video.videoId && <span style="font-family:monospace;background:#222;padding:8px 12px;border-radius:6px;color:#888;font-size:12px;letter-spacing:0.5px;margin-left:auto;">ID {video.videoId}</span>}
      </div>
    </div>

    {/* Row 3: Ähnliche Videos (volle Breite) */}
    {similar.length > 0 && (
      <section class="similar-wrap">
        <h2 class="similar-head">Ähnliche Videos</h2>
        <div class="similar-grid">
          {similar.map(s => (
            <a href={`/video/${s.slug}/`} class="similar-card">
              <div class="similar-thumb">
                {s.thumbnail ? <img src={s.thumbnail} alt={s.title} loading="lazy" /> : <div class="similar-bg" style={`background:${s.gradient || '#222'}`}></div>}
                <span class={`res-badge ${s.resolution === '4K' ? 'res-4k' : 'res-hd'}`} style="position:absolute;top:10px;left:10px;">{s.resolution}</span>
                <span class="dur-badge" style="position:absolute;bottom:10px;right:10px;">{s.duration}</span>
              </div>
              <div class="similar-info">
                <span class="similar-title">{s.title}</span>
                <span class="similar-price">{s.price || (s.prices && s.prices.web) || 0} €</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {/* Row 4: Schlagwörter (volle Breite, klickbar, ohne #) */}
    {video.tags && video.tags.length > 0 && (
      <section class="tags-wrap">
        <h3 class="tags-head">Schlagwörter</h3>
        <div class="tags-row">
          {video.tags.map(tag => (
            <a href={`/?q=${encodeURIComponent(tag)}`} class="tag-chip">{tag}</a>
          ))}
        </div>
      </section>
    )}
  </div>

  <script define:vars={{ videoId: video.id, videoTitle: video.title, price, slug: video.slug, r2Key: video.r2Key }}>
    var container = document.getElementById('videoContainer');
    var poster = document.getElementById('videoPoster');
    var player = document.getElementById('videoPlayer');
    if (container && player) {
      container.addEventListener('click', function() {
        if (player.style.display === 'none' || player.style.display === '') {
          player.style.display = 'block';
          poster.style.display = 'none';
          player.play();
        }
      });
    }
    var dlBtn=document.getElementById('dlPreviewBtn');
    if(dlBtn){
      dlBtn.addEventListener('click',function(){
        var key=dlBtn.dataset.key;var name=dlBtn.dataset.name||'preview.mp4';
        if(!key)return;
        var a=document.createElement('a');
        a.href='/dl/'+key+'?name='+encodeURIComponent(name);
        a.download=name;
        document.body.appendChild(a);a.click();a.remove();
      });
    }

    var CHECKOUT_WORKER = 'https://stockvideo-checkout.rende.workers.dev';
    var buyBtn = document.getElementById('buyBtn');
    var spinner = document.getElementById('buySpinner');
    var errorEl = document.getElementById('buyError');

    if (buyBtn) {
      buyBtn.addEventListener('click', function() {
      const params = new URLSearchParams({
        id: videoId,
        title: videoTitle,
        price: String(price),
        slug: slug
      });
      window.location.href = '/checkout/billing?' + params.toString();
    });
    }
  </script>

  <style>
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Badges oben rechts im Video-Player: flex-Gruppe, Badge-Klassen neutralisiert */
    .detail-badges{position:absolute;top:16px;right:16px;z-index:2;display:flex;gap:8px;align-items:center;}
    .detail-badges > *{position:static;top:auto;right:auto;bottom:auto;left:auto;flex:0 0 auto;}
    .detail-badges .res-badge{padding:4px 10px;font-size:11px;border-radius:4px;line-height:1;}
    .detail-badges .dur-badge{padding:4px 10px;font-size:11px;border-radius:4px;line-height:1;}
    .detail-badges .preview-badge{background:rgba(0,0,0,0.6);color:#fff;padding:4px 10px;border-radius:4px;font-size:11px;letter-spacing:0.5px;line-height:1;}

    /* Row 1: Video + Preisbox — gleiche Höhe via Grid align-items:stretch (default) */
    .video-top-row{display:grid;grid-template-columns:1.7fr 1fr;gap:28px;align-items:stretch;margin-bottom:20px}
    .video-col{min-width:0}
    .price-col{min-width:0;display:flex}
    .price-box{
      flex:1;
      display:flex;flex-direction:column;justify-content:space-between;gap:14px;
      background:linear-gradient(135deg,#1a2a1a,#1e2e1e);
      border:1px solid #2d4a2d;border-radius:12px;padding:22px 22px 20px;
    }
    .price-benefits{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:6px;font-size:13px;color:#b5c5b5;}
    .price-benefits li{padding-left:22px;position:relative;line-height:1.4;}
    .price-benefits li::before{content:'✓';position:absolute;left:0;top:0;color:#4ade80;font-weight:700;}

    /* Row 2: Meta bleibt an linker Spalte ausgerichtet */
    .video-meta{margin-bottom:40px;}

    /* Row 3: Ähnliche Videos */
    .similar-wrap{margin:8px 0 44px;}
    .similar-head{font-size:20px;font-weight:700;margin:0 0 16px;color:#eee;}
    .similar-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
    .similar-card{display:block;text-decoration:none;color:inherit;border-radius:8px;overflow:hidden;background:#1a1a1a;transition:transform .15s ease;}
    .similar-card:hover{transform:translateY(-2px);}
    .similar-thumb{position:relative;aspect-ratio:16/9;overflow:hidden;background:#222;}
    .similar-thumb img{width:100%;height:100%;object-fit:cover;display:block;}
    .similar-bg{position:absolute;inset:0;}
    .similar-info{padding:10px 12px;display:flex;justify-content:space-between;align-items:center;gap:10px;}
    .similar-title{font-size:13px;color:#ddd;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;min-width:0;}
    .similar-price{font-size:13px;color:#4ade80;font-weight:600;flex-shrink:0;}

    /* Row 4: Tag-Chips */
    .tags-wrap{margin:0 0 40px;padding-top:24px;border-top:1px solid #222;}
    .tags-head{font-size:14px;font-weight:600;color:#999;text-transform:uppercase;letter-spacing:1.2px;margin:0 0 14px;}
    .tags-row{display:flex;flex-wrap:wrap;gap:8px;}
    .tag-chip{display:inline-block;background:#2c2c2c;color:#ccc;padding:6px 14px;border-radius:14px;font-size:13px;text-decoration:none;transition:background .15s ease,color .15s ease;}
    .tag-chip:hover{background:var(--accent,#2563eb);color:#fff;}

    /* Mobil: Ein-Spalten-Layout */
    @media (max-width:900px){
      .video-top-row{grid-template-columns:1fr;}
      .similar-grid{grid-template-columns:repeat(2,1fr);}
    }
    @media (max-width:520px){
      .similar-grid{grid-template-columns:1fr;}
    }
  </style>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": video.title,
    "description": video.description,
    "thumbnailUrl": `https://stockvideo.de/thumbnails/${video.slug}.jpg`,
    "duration": `PT${String(video.duration).replace("0:", "")}S`,
    "contentUrl": videoUrl || `https://stockvideo.de/video/${video.slug}`,
    "offers": {
      "@type": "Offer",
      "price": price.toFixed(2),
      "priceCurrency": "EUR"
    }
  })} />

  <Footer />
</BaseLayout>
