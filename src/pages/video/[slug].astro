---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import VideoCard from '../../components/VideoCard.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const allVideos = await getCollection('videos');
  return allVideos.map(video => ({
    params: { slug: video.id },
    props: { video },
  }));
}

const { video } = Astro.props;
const { data } = video;

// Related videos (same category, exclude current)
const allVideos = await getCollection('videos');
const related = allVideos
  .filter(v => v.data.category === data.category && v.id !== video.id)
  .slice(0, 4);

const categoryLabels: Record<string, string> = {
  business:    'Business',
  natur:       'Natur & Landschaft',
  lifestyle:   'Lifestyle',
  architektur: 'Architektur',
  technologie: 'Technologie',
  sport:       'Sport',
};

const formatDuration = (s: number) => {
  const m = Math.floor(s / 60);
  const sec = s % 60;
  return m > 0 ? `${m}:${sec.toString().padStart(2, '0')} min` : `${sec} Sek.`;
};

const videoSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: data.title,
  description: data.description,
  thumbnailUrl: `https://stockvideo.de${data.thumbnail ?? '/og-image.jpg'}`,
  uploadDate: new Date().toISOString(),
  duration: `PT${Math.floor(data.duration / 60)}M${data.duration % 60}S`,
  contentUrl: `https://stockvideo.de/video/${video.id}`,
};
---

<BaseLayout
  title={`${data.title} — stockvideo.de`}
  description={data.description}
>
  <!-- Video Schema.org -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(videoSchema)} />

  <Navbar />
  <main>
    <!-- Breadcrumb -->
    <div class="breadcrumb-bar">
      <div class="container">
        <nav aria-label="Breadcrumb">
          <ol class="breadcrumb">
            <li><a href="/" class="breadcrumb__link">Start</a><span aria-hidden="true"> / </span></li>
            <li><a href={`/kategorie/${data.category}`} class="breadcrumb__link">{categoryLabels[data.category] ?? data.category}</a><span aria-hidden="true"> / </span></li>
            <li><span aria-current="page">{data.title}</span></li>
          </ol>
        </nav>
      </div>
    </div>

    <div class="container video-detail section">
      <div class="video-detail__main">
        <!-- Preview -->
        <div class="video-preview">
          {data.thumbnail ? (
            <img
              src={data.thumbnail}
              alt={`Vorschau: ${data.title}`}
              class="video-preview__img"
              width="1280"
              height="720"
            />
          ) : (
            <div class="video-preview__placeholder" aria-label="Keine Vorschau verfügbar">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
                <polygon points="5,3 19,12 5,21"/>
              </svg>
            </div>
          )}
          <div class="video-preview__overlay" aria-hidden="true">
            <div class="video-preview__play">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="white"><polygon points="5,3 19,12 5,21"/></svg>
            </div>
            <span>Vorschau</span>
          </div>
        </div>

        <!-- Info -->
        <div class="video-info">
          <div class="video-info__meta">
            <a href={`/kategorie/${data.category}`} class="tag">{categoryLabels[data.category] ?? data.category}</a>
            <span class="video-info__spec">{data.resolution}</span>
            <span class="video-info__spec">{data.fps} fps</span>
            <span class="video-info__spec">{formatDuration(data.duration)}</span>
          </div>

          <h1 class="video-info__title">{data.title}</h1>
          <p class="video-info__desc">{data.description}</p>

          <div class="video-info__tags" aria-label="Tags">
            {data.tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
      </div>

      <!-- Pricing Sidebar -->
      <aside class="video-sidebar" aria-label="Lizenzoptionen">
        <div class="license-box">
          <h2 class="license-box__title">Lizenz wählen</h2>

          {[
            { key: 'web', label: 'Web-Lizenz', price: data.price.web, desc: 'Online, Social Media, bis 1 Mio. Views' },
            { key: 'broadcast', label: 'Broadcast-Lizenz', price: data.price.broadcast, desc: 'TV, Kino, unlimitierte Zuschauer' },
            { key: 'extended', label: 'Extended-Lizenz', price: data.price.extended, desc: 'Print, Templates, Weiterverkauf' },
          ].map((plan, i) => (
            <label class={`license-option ${i === 0 ? 'license-option--selected' : ''}`}>
              <input type="radio" name="license" value={plan.key} class="license-option__radio" checked={i === 0} />
              <div class="license-option__content">
                <div class="license-option__name">{plan.label}</div>
                <div class="license-option__desc">{plan.desc}</div>
              </div>
              <div class="license-option__price">€{plan.price}</div>
            </label>
          ))}

          <a href="/preise" class="btn btn-primary" style="width: 100%; justify-content: center; margin-top: 8px;">
            Jetzt lizenzieren
          </a>
          <p class="license-box__note">
            Einmalzahlung · Sofort-Download · Dauerhaftes Nutzungsrecht
          </p>
          <a href="/lizenzen" class="license-box__more">Alle Lizenzdetails →</a>
        </div>

        <div class="video-specs-box">
          <h3>Technische Details</h3>
          <dl class="specs-list">
            <div class="specs-item"><dt>Auflösung</dt><dd>{data.resolution}</dd></div>
            <div class="specs-item"><dt>Bildrate</dt><dd>{data.fps} fps</dd></div>
            <div class="specs-item"><dt>Länge</dt><dd>{formatDuration(data.duration)}</dd></div>
            <div class="specs-item"><dt>Kategorie</dt><dd>{categoryLabels[data.category] ?? data.category}</dd></div>
          </dl>
        </div>
      </aside>
    </div>

    <!-- Related Videos -->
    {related.length > 0 && (
      <section class="section" style="border-top: 1px solid var(--color-border);">
        <div class="container">
          <h2 style="margin-bottom: 28px;">Ähnliche Videos</h2>
          <div class="grid-4">
            {related.map(v => (
              <VideoCard
                slug={v.id}
                title={v.data.title}
                description={v.data.description}
                category={v.data.category}
                resolution={v.data.resolution}
                duration={v.data.duration}
                thumbnail={v.data.thumbnail}
                price={v.data.price}
              />
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
  <Footer />
</BaseLayout>

<style>
.breadcrumb-bar {
  background: var(--color-bg-2);
  border-bottom: 1px solid var(--color-border);
  padding: 10px 0;
}
.breadcrumb {
  display: flex;
  gap: 4px;
  align-items: center;
  flex-wrap: wrap;
  font-size: 0.8125rem;
  color: var(--color-text-faint);
}
.breadcrumb__link { color: var(--color-text-muted); }
.breadcrumb__link:hover { color: var(--color-accent); }

/* Layout */
.video-detail {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 40px;
  align-items: start;
}
.video-detail__main { display: flex; flex-direction: column; gap: 28px; }

/* Preview */
.video-preview {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  aspect-ratio: 16/9;
  background: var(--color-bg-3);
  cursor: pointer;
}
.video-preview__img { width: 100%; height: 100%; object-fit: cover; }
.video-preview__placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  color: var(--color-text-faint);
}
.video-preview__overlay {
  position: absolute; inset: 0;
  background: rgba(0,0,0,0.4);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 8px;
  color: #fff;
  font-size: 0.875rem;
  font-weight: 600;
  opacity: 0;
  transition: opacity var(--transition);
}
.video-preview:hover .video-preview__overlay { opacity: 1; }
.video-preview__play {
  width: 64px; height: 64px;
  border-radius: 50%;
  background: rgba(232,23,60,0.85);
  display: flex; align-items: center; justify-content: center;
}

/* Info */
.video-info__meta {
  display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
  margin-bottom: 12px;
}
.video-info__spec {
  font-size: 0.8rem;
  color: var(--color-text-faint);
  background: var(--color-bg-3);
  border: 1px solid var(--color-border);
  padding: 3px 9px;
  border-radius: 4px;
}
.video-info__title { font-size: 1.75rem; margin-bottom: 12px; }
.video-info__desc { font-size: 0.9375rem; line-height: 1.7; }
.video-info__tags { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }

/* Sidebar */
.video-sidebar { display: flex; flex-direction: column; gap: 16px; position: sticky; top: 80px; }

.license-box {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 24px;
}
.license-box__title { font-size: 1.0625rem; margin-bottom: 16px; }

.license-option {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 14px;
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius);
  cursor: pointer;
  transition: all var(--transition);
  margin-bottom: 8px;
}
.license-option:hover { border-color: var(--color-accent); }
.license-option--selected { border-color: var(--color-accent); background: var(--color-accent-soft); }
.license-option__radio { accent-color: var(--color-accent); }
.license-option__content { flex: 1; }
.license-option__name { font-size: 0.9rem; font-weight: 600; }
.license-option__desc { font-size: 0.775rem; color: var(--color-text-muted); }
.license-option__price { font-size: 1.0625rem; font-weight: 700; color: var(--color-text); white-space: nowrap; }

.license-box__note {
  text-align: center;
  font-size: 0.775rem;
  color: var(--color-text-faint);
  margin-top: 10px;
}
.license-box__more {
  display: block;
  text-align: center;
  font-size: 0.8125rem;
  color: var(--color-text-muted);
  margin-top: 8px;
}
.license-box__more:hover { color: var(--color-accent); }

.video-specs-box {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 20px 24px;
}
.video-specs-box h3 { font-size: 0.9375rem; margin-bottom: 14px; }
.specs-list { display: flex; flex-direction: column; gap: 8px; }
.specs-item { display: flex; justify-content: space-between; align-items: center; }
.specs-item dt { font-size: 0.8375rem; color: var(--color-text-muted); }
.specs-item dd { font-size: 0.8375rem; font-weight: 600; color: var(--color-text); }

@media (max-width: 900px) {
  .video-detail { grid-template-columns: 1fr; }
  .video-sidebar { position: static; }
}
</style>
