---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Topbar from '../../components/Topbar.astro';
import Footer from '../../components/Footer.astro';
import videos from '../../../public/data/videos.json';
import categories from '../../../public/data/categories.json';

export function getStaticPaths() {
  return videos.map(v => ({ params: { slug: v.slug } }));
}

const { slug } = Astro.params;
const video = videos.find(v => v.slug === slug);
if (!video) return Astro.redirect('/');
const cat = categories.find(c => c.dataCat === video.category);
const r2Base = 'https://pub-03757a2d41d2442dabdeaa0a62f5d1ad.r2.dev';

const previewUrl = video.r2Preview ? r2Base + '/' + video.r2Preview : '';
const videoUrl = previewUrl || (video.r2Key ? r2Base + '/' + video.r2Key : '');
const price = video.price || (video.prices && video.prices.web) || 5;
// Preis ist Brutto inkl. 19% MwSt. Aufschluesselung fuer transparente Anzeige.
const vatRate = 0.19;
const priceNet = price / (1 + vatRate);
const priceVat = price - priceNet;
const fmt = (n: number) => n.toFixed(2).replace('.', ',');
---

<BaseLayout title={video.title} description={video.description}>
  <Topbar />
  <div class="page-content" style="max-width:1200px;">
    <div style="margin-bottom:8px;">
      <a href="/" style="color:var(--accent);font-size:14px;">← Zurück zur Übersicht</a>
      {cat && <span style="color:#666;font-size:14px;margin-left:12px;">/ <a href={`/kategorie/${video.category}`} style="color:var(--accent);">{cat.label}</a></span>}
    </div>

    <div class="video-layout">
    <div class="video-col">
    <div id="videoContainer" style="aspect-ratio:16/9;border-radius:10px;overflow:hidden;margin-bottom:32px;position:relative;cursor:pointer;">
      {videoUrl && (
        <video id="videoPlayer" style="width:100%;height:100%;object-fit:cover;display:none;"
          controls controlsList="nodownload" disablePictureInPicture
          oncontextmenu="return false" preload="metadata" poster={video.thumbnail}><source src={videoUrl} type="video/mp4" />
        </video>
      )}
      <div id="videoPoster" style={`position:absolute;inset:0;background:#000 center/cover no-repeat url(${video.thumbnail});`}>
        <div style="position:absolute;inset:0;background:radial-gradient(circle at 25% 35%,rgba(255,255,255,0.06) 0%,transparent 45%),radial-gradient(circle at 75% 65%,rgba(255,255,255,0.04) 0%,transparent 35%);opacity:0.35;"></div>
        <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
          <div id="playBtn" style="width:72px;height:72px;border-radius:50%;background:rgba(255,255,255,0.95);display:flex;align-items:center;justify-content:center;box-shadow:0 4px 24px rgba(0,0,0,0.4);transition:transform 0.2s;">
            <svg width="24" height="24" viewBox="0 0 16 16" fill="#1b1b1b"><path d="M4 2l10 6-10 6z"/></svg>
          </div>
        </div>
      </div>
      {video.r2Preview && <span style="position:absolute;top:16px;right:16px;z-index:2;background:rgba(0,0,0,0.6);color:#fff;padding:4px 10px;border-radius:4px;font-size:11px;letter-spacing:0.5px;">VORSCHAU</span>}
      <span class={`res-badge ${video.resolution === '4K' ? 'res-4k' : 'res-hd'}`} style="position:absolute;top:16px;left:16px;z-index:2;">{video.resolution}</span>
      <!--wm--><div id="wmOverlay" style="position:absolute;inset:0;z-index:3;pointer-events:none;display:flex;align-items:center;justify-content:center;overflow:hidden;"><div style="position:absolute;inset:0;display:grid;grid-template-columns:repeat(4,1fr);grid-template-rows:repeat(4,1fr);transform:rotate(-22deg);">{Array.from({length:16}).map(()=>(<div style="display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.22);font-size:clamp(14px,2vw,22px);font-weight:700;letter-spacing:2px;text-shadow:0 1px 4px rgba(0,0,0,0.6);user-select:none;">stockvideo.de</div>))}</div></div>
      <span class="dur-badge" style="position:absolute;bottom:16px;right:16px;z-index:2;">{video.duration}</span>
    </div>

    {video.r2Preview && (
    <div style="display:flex;gap:10px;align-items:center;margin:0 0 16px;flex-wrap:wrap;">
      <button id="dlPreviewBtn" data-key={video.r2Preview} data-name={`stockvideo-${video.slug}-preview${video.r2Preview && video.r2Preview.endsWith('.webm') ? '.webm' : '.mp4'}`} class="btn-primary" style="padding:12px 22px;border-radius:6px;font-size:14px;font-weight:700;color:#fff;border:none;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:10px;background:var(--accent,#2563eb);">⬇ Vorschau (480p) herunterladen</button>
      {video.videoId && <span style="font-family:monospace;background:#222;padding:6px 12px;border-radius:4px;color:#888;font-size:12px;letter-spacing:0.5px;">ID {video.videoId}</span>}
    </div>
  )}
  </div>
    <div class="info-col">
    <h1 style="font-size:clamp(22px,3vw,32px);">{video.title}</h1>
    <p>{video.description}</p>

    <div style="display:flex;gap:8px;flex-wrap:wrap;margin:16px 0 24px;">
      {video.tags.map(tag => (
        <span style="background:#2c2c2c;color:#999;padding:4px 12px;border-radius:12px;font-size:13px;">#{tag}</span>
      ))}
    </div>

    <div style="display:flex;gap:8px;flex-wrap:wrap;margin:16px 0 32px;">
      <span style="background:#2a2a2a;padding:8px 16px;border-radius:6px;font-size:13px;color:#ccc;">Auflösung: {video.resolution}</span>
      <span style="background:#2a2a2a;padding:8px 16px;border-radius:6px;font-size:13px;color:#ccc;">Dauer: {video.duration}</span>
      <span style="background:#2a2a2a;padding:8px 16px;border-radius:6px;font-size:13px;color:#ccc;">{video.fps} FPS</span>
      <span style="background:#2a2a2a;padding:8px 16px;border-radius:6px;font-size:13px;color:#ccc;">MP4 / MOV</span>
    </div>

    <div style="background:linear-gradient(135deg,#1a2a1a,#1e2e1e);border:1px solid #2d4a2d;border-radius:12px;padding:32px;text-align:center;margin-bottom:32px;">
      <div style="font-size:42px;font-weight:700;color:#4ade80;margin-bottom:4px;">{fmt(price)} €</div>
      <div style="color:#8a9a8a;font-size:12px;margin-bottom:12px;">Bruttopreis inkl. 19 % MwSt.</div>
      <div style="display:flex;justify-content:center;gap:18px;flex-wrap:wrap;font-size:12px;color:#b5c5b5;margin-bottom:18px;">
        <span>Netto: <strong style="color:#d1e5d1;">{fmt(priceNet)} €</strong></span>
        <span style="color:#4a5a4a;">·</span>
        <span>MwSt. 19 %: <strong style="color:#d1e5d1;">{fmt(priceVat)} €</strong></span>
      </div>
      <div style="color:#999;font-size:14px;margin-bottom:24px;">Einmalige Zahlung · Sofortiger Download · Lizenz inklusive · MwSt.-Rechnung nach Kauf</div>
      <button id="buyBtn" class="btn-primary" style="padding:16px 48px;font-size:18px;border-radius:8px;cursor:pointer;min-width:240px;">
        Jetzt kaufen
      </button>
      <div id="buySpinner" style="display:none;margin-top:16px;color:#999;align-items:center;justify-content:center;">
        Weiterleitung zu Mollie...
      </div>
      <div id="buyError" style="display:none;margin-top:16px;color:#ef4444;font-size:14px;"></div>
    </div>

    <div style="background:#1e1e1e;border-radius:8px;padding:20px;margin-bottom:32px;">
      <h3 style="font-size:16px;margin-bottom:12px;color:#ccc;">Was ist enthalten?</h3>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;color:#999;font-size:14px;">
        <div>✓ Originaldatei in {video.resolution}</div>
        <div>✓ Kommerzielle Nutzung</div>
        <div>✓ Unbegrenzte Projekte</div>
        <div>✓ Sofortiger Download</div>
      </div>
    </div>

    </div>
  </div>
</div>

  <script define:vars={{ videoId: video.id, videoTitle: video.title, price, slug: video.slug, r2Key: video.r2Key }}>
    var container = document.getElementById('videoContainer');
    var poster = document.getElementById('videoPoster');
    var player = document.getElementById('videoPlayer');
    if (container && player) {
      container.addEventListener('click', function() {
        if (player.style.display === 'none' || player.style.display === '') {
          player.style.display = 'block';
          poster.style.display = 'none';
          player.play();
        }
      });
    }
    var dlBtn=document.getElementById('dlPreviewBtn');
    if(dlBtn){
      dlBtn.addEventListener('click',function(){
        var key=dlBtn.dataset.key;var name=dlBtn.dataset.name||'preview.mp4';
        if(!key)return;
        var a=document.createElement('a');
        a.href='/dl/'+key+'?name='+encodeURIComponent(name);
        a.download=name;
        document.body.appendChild(a);a.click();a.remove();
      });
    }

    var CHECKOUT_WORKER = 'https://stockvideo-checkout.rende.workers.dev';
    var buyBtn = document.getElementById('buyBtn');
    var spinner = document.getElementById('buySpinner');
    var errorEl = document.getElementById('buyError');

    if (buyBtn) {
      buyBtn.addEventListener('click', function() {
      const params = new URLSearchParams({
        id: videoId,
        title: videoTitle,
        price: String(price),
        slug: slug
      });
      window.location.href = '/checkout/billing?' + params.toString();
    });
    }
  </script>

  <style>
    @keyframes spin { to { transform: rotate(360deg); } }
.video-layout{display:grid;grid-template-columns:1.7fr 1fr;gap:28px;align-items:start;margin-bottom:24px}
.video-col{min-width:0}
.info-col{min-width:0}
.info-col h1{margin-top:0}
@media (max-width:900px){.video-layout{grid-template-columns:1fr}}
  </style>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": video.title,
    "description": video.description,
    "thumbnailUrl": `https://stockvideo.de/thumbnails/${video.slug}.jpg`,
    "duration": `PT${String(video.duration).replace("0:", "")}S`,
    "contentUrl": videoUrl || `https://stockvideo.de/video/${video.slug}`,
    "offers": {
      "@type": "Offer",
      "price": price.toFixed(2),
      "priceCurrency": "EUR"
    }
  })} />

  <Footer />
</BaseLayout>