      <div class="legal-block">
        <h2>Anbieter</h2>
        <p>
          stockvideo.de<br />
          Inhaber: Timo Rende<br />
          Haldenstraße 16<br />
          66806 Saarlouis / Ensdorf
        </p>
      </div>

      <div class="legal-block">
        <h2>Kontakt</h2>
        <p>
          Telefon: 06831 5052856<br />
          Fax: 06831 5051619<br />
          E-Mail: <a href="mailto:info@stockvideo.de">info@stockvideo.de</a><br />
          Website: stockvideo.de
        </p>
      </div>

