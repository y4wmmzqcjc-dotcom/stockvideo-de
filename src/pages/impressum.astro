}
.legal-block h2 {
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 8px;
}
.legal-block h3 {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 8px;
}
.legal-block p {
  font-size: 0.9rem;
  color: var(--color-text-muted);
  line-height: 1.75;
}
.legal-block a {
  color: var(--color-accent);
}
</style>
