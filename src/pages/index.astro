---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import VideoGrid from '../components/VideoGrid.astro';
import FeaturesGrid from '../components/FeaturesGrid.astro';
import PricingSection from '../components/PricingSection.astro';
import CategoryStrip from '../components/CategoryStrip.astro';
import config from '../data/config.json';
import videos from '../data/videos.json';

const featuredVideos = videos.filter(v => v.featured === true);
const allVideos = videos;
---

<BaseLayout
  title="Lizenzfreie Stock Videos in 4K & HD"
  description={config.siteDescription}
>
  <Navbar />
  <Hero />
  <CategoryStrip />

  <!-- Featured Videos Section -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Ausgewählte Videos</h2>
        <p>Entdecken Sie unsere handverlesene Auswahl an Premium-Videos</p>
      </div>
      <VideoGrid videos={featuredVideos} />
    </div>
  </section>

  <!-- All Videos Section -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Neueste Videos</h2>
        <p>Alle verfügbaren Videos in unserer Bibliothek</p>
      </div>
      <VideoGrid videos={allVideos} showMore={true} />
    </div>
  </section>

  <!-- Features Section -->
  <FeaturesGrid />

  <!-- Pricing Section -->
  <PricingSection />

  <Footer />
</BaseLayout>

<style>
  .section {
    padding: 4rem 0;
    background: linear-gradient(135deg, #0a0e27 0%, #1a1f3a 100%);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-header h2 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: #fff;
    font-weight: 700;
  }

  .section-header p {
    font-size: 1.1rem;
    color: #9ca3af;
  }

  @media (max-width: 768px) {
    .section {
      padding: 2rem 0;
    }

    .section-header h2 {
      font-size: 1.8rem;
    }
  }
</style>
