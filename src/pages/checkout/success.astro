---
import BaseLayout from '../../layouts/BaseLayout.astro';
const CHECKOUT_WORKER = 'https://stockvideo-checkout.rende.workers.dev';
---
<BaseLayout title="Bestellung erfolgreich – stockvideo.de">
  <main class="success-wrap">
    <section id="loading" class="state-box">
      <div class="spinner"></div>
      <h2>Bestellung wird verarbeitet …</h2>
      <p>Wir prüfen gerade deinen Zahlungsstatus. Bitte kurz warten.</p>
    </section>

    <section id="paid" class="state-box" hidden>
      <div class="check-icon">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
      </div>
      <h1>Vielen Dank für deinen Kauf!</h1>
      <p class="lead">Deine Zahlung wurde erfolgreich verarbeitet.</p>

      <div class="card">
        <h3>Bestelldetails</h3>
        <dl class="details">
          <dt>Bestellnummer</dt><dd id="dOrderId" class="mono">–</dd>
          <dt>Video</dt><dd id="dTitle">–</dd>
          <dt>Betrag</dt><dd id="dAmount">–</dd>
          <dt>Datum</dt><dd id="dPaidAt">–</dd>
        </dl>
      </div>

      <div class="card">
        <h3>Downloads</h3>
        <p class="hint">Lade dein Video und die Lizenzurkunde herunter. Beide Links bleiben 7 Tage gültig.</p>
        <div class="dl-grid">
          <a id="videoLink" href="#" class="dl-btn primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Video herunterladen
          </a>
          <a id="pdfLink" href="#" target="_blank" class="dl-btn secondary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Lizenzurkunde (PDF)
          </a>
        </div>
      </div>

      <a href="/" class="back-link">← Zurück zur Startseite</a>
    </section>

    <section id="failed" class="state-box" hidden>
      <div class="x-icon">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
      </div>
      <h1>Zahlung nicht erfolgreich</h1>
      <p class="lead" id="failMsg">Deine Bestellung konnte nicht verarbeitet werden.</p>
      <a href="/" class="btn-primary">Zur Startseite</a>
    </section>
  </main>

  <style>
    .success-wrap {
      max-width: 640px;
      margin: 0 auto;
      padding: 48px 20px 80px;
    }
    .state-box {
      text-align: center;
    }
    .state-box h1 {
      font-size: 28px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 8px;
      letter-spacing: -0.02em;
    }
    .state-box h2 {
      font-size: 20px;
      font-weight: 600;
      color: #fff;
      margin-top: 20px;
      margin-bottom: 6px;
    }
    .state-box .lead {
      color: #b8b8b8;
      font-size: 15px;
      margin-bottom: 28px;
    }
    .state-box p {
      color: #9a9a9a;
      font-size: 14px;
    }
    .spinner {
      width: 48px;
      height: 48px;
      border: 4px solid #2c2c2c;
      border-top-color: #1473e6;
      border-radius: 50%;
      margin: 40px auto 0;
      animation: spin 0.9s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .check-icon {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      background: rgba(20, 115, 230, 0.12);
      color: #1473e6;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
    }
    .x-icon {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      background: rgba(220, 38, 38, 0.12);
      color: #ef4444;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin: 40px auto 16px;
    }
    .card {
      background: #222;
      border: 1px solid #3a3a3a;
      border-radius: 12px;
      padding: 24px;
      margin-top: 20px;
      text-align: left;
    }
    .card h3 {
      font-size: 14px;
      font-weight: 600;
      color: #c8c8c8;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 14px;
    }
    .details {
      display: grid;
      grid-template-columns: 140px 1fr;
      gap: 10px 16px;
      font-size: 14px;
    }
    .details dt { color: #8a8a8a; }
    .details dd { color: #fff; word-break: break-all; }
    .mono { font-family: 'Fira Code', 'Monaco', monospace; font-size: 13px; }
    .hint { color: #9a9a9a; font-size: 13px; margin-bottom: 14px; }
    .dl-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    @media (max-width: 520px) { .dl-grid { grid-template-columns: 1fr; } }
    .dl-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 13px 16px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      text-decoration: none;
      transition: background 0.15s, transform 0.05s;
    }
    .dl-btn.primary {
      background: #1473e6;
      color: #fff;
    }
    .dl-btn.primary:hover { background: #0d66d0; }
    .dl-btn.secondary {
      background: #2c2c2c;
      color: #fff;
      border: 1px solid #3a3a3a;
    }
    .dl-btn.secondary:hover { background: #333; }
    .dl-btn:active { transform: translateY(1px); }
    .back-link {
      display: inline-block;
      margin-top: 28px;
      color: #8a8a8a;
      font-size: 14px;
      text-decoration: none;
    }
    .back-link:hover { color: #1473e6; }
    .btn-primary {
      display: inline-block;
      background: #1473e6;
      color: #fff;
      padding: 12px 24px;
      border-radius: 8px;
      font-weight: 600;
      text-decoration: none;
      margin-top: 20px;
    }
    .btn-primary:hover { background: #0d66d0; }
  </style>

  <script is:inline define:vars={{ CHECKOUT_WORKER }}>
    const params = new URLSearchParams(window.location.search);
    const orderId = params.get('order') || params.get('orderId');
    const loading = document.getElementById('loading');
    const paid = document.getElementById('paid');
    const failed = document.getElementById('failed');

    function show(el) {
      loading.hidden = true;
      paid.hidden = true;
      failed.hidden = true;
      el.hidden = false;
    }

    function fail(msg) {
      document.getElementById('failMsg').textContent = msg;
      show(failed);
    }

    if (!orderId) {
      fail('Keine Bestellnummer angegeben.');
    } else {
      pollOrder(0);
    }

    async function pollOrder(attempt) {
      try {
        const r = await fetch(CHECKOUT_WORKER + '/order/' + encodeURIComponent(orderId));
        if (r.status === 404) {
          if (attempt < 10) return setTimeout(() => pollOrder(attempt+1), 1500);
          return fail('Bestellung nicht gefunden.');
        }
        if (!r.ok) throw new Error('Fehler beim Laden der Bestellung');
        const order = await r.json();
        if (order.status === 'paid') {
          await showPaid(order);
        } else if (['failed','expired','canceled'].includes(order.status)) {
          fail('Status: ' + order.status);
        } else if (attempt < 40) {
          setTimeout(() => pollOrder(attempt+1), 2000);
        } else {
          fail('Zeitüberschreitung. Bitte später erneut prüfen.');
        }
      } catch(e) {
        if (attempt < 5) return setTimeout(() => pollOrder(attempt+1), 2000);
        fail(e.message || 'Unbekannter Fehler');
      }
    }

    async function showPaid(order) {
      document.getElementById('dOrderId').textContent = order.id;
      document.getElementById('dTitle').textContent = (order.video && order.video.title) || '–';
      document.getElementById('dAmount').textContent = (Number(order.amount) || 0).toFixed(2).replace('.',',') + ' ' + (order.currency || 'EUR');
      document.getElementById('dPaidAt').textContent = order.paidAt ? new Date(order.paidAt).toLocaleString('de-DE') : '–';

      try {
        const dr = await fetch(CHECKOUT_WORKER + '/download-url/' + encodeURIComponent(order.id));
        const dl = await dr.json();
        let videoUrl = dl.videoUrl;
        if (!videoUrl && order.video && order.video.id) {
          try {
            const vr = await fetch(CHECKOUT_WORKER + '/video/' + encodeURIComponent(order.video.id));
            if (vr.ok) {
              const v = await vr.json();
              videoUrl = v.url || v.videoUrl || (v.video && v.video.url);
            }
          } catch(_) {}
        }
        document.getElementById('videoLink').href = videoUrl || '#';
        if (videoUrl) document.getElementById('videoLink').setAttribute('download','');
        document.getElementById('pdfLink').href = dl.pdfUrl || '#';
      } catch(_) {}

      show(paid);
    }
  </script>
</BaseLayout>
