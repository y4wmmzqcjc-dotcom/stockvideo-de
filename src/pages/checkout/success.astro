---
import BaseLayout from '../../layouts/BaseLayout.astro';
const CHECKOUT_WORKER = 'https://stockvideo-checkout.rende.workers.dev';
---
<BaseLayout title="Zahlung erfolgreich">
  <main class="container" style="max-width:720px;margin:4rem auto;padding:2rem;text-align:center;">
    <h1 style="font-size:2rem;margin-bottom:1rem;">Zahlung erfolgreich</h1>
    <p id="statusText" style="margin-bottom:2rem;color:#666;">Ihr Download wird vorbereitet…</p>

    <div id="downloadBox" style="display:none;padding:2rem;background:#f7fff7;border:1px solid #c4e9c4;border-radius:12px;margin-bottom:2rem;">
      <p style="font-weight:600;margin-bottom:1rem;">✓ <span id="videoTitle">Ihr Video</span> ist bereit</p>
      <a id="downloadBtn" href="#" download
         style="display:inline-block;padding:1rem 2rem;background:#16a34a;color:#fff;text-decoration:none;border-radius:8px;font-weight:600;">
        Video herunterladen
      </a>
      <p style="margin-top:1rem;font-size:.85rem;color:#666;">Der Download startet automatisch. Falls nicht, klicken Sie auf den Button.</p>
    </div>

    <div id="errorBox" style="display:none;padding:1.5rem;background:#fff4f4;border:1px solid #f5c2c2;border-radius:12px;margin-bottom:2rem;">
      <p id="errorText" style="color:#c62828;"></p>
    </div>

    <a href="/" style="color:#666;text-decoration:underline;">← Zurück zur Startseite</a>
  </main>

  <script define:vars={{ CHECKOUT_WORKER }}>
    const params = new URLSearchParams(window.location.search);
    const paymentId = params.get('payment_id');
    const slug = params.get('slug') || '';

    const statusText = document.getElementById('statusText');
    const downloadBox = document.getElementById('downloadBox');
    const downloadBtn = document.getElementById('downloadBtn');
    const videoTitle  = document.getElementById('videoTitle');
    const errorBox    = document.getElementById('errorBox');
    const errorText   = document.getElementById('errorText');

    function showError(msg) {
      statusText.style.display = 'none';
      errorBox.style.display = 'block';
      errorText.textContent = msg;
    }

    if (!paymentId || paymentId === '{id}' || paymentId === '%7Bid%7D') {
      showError('Fehlende Zahlungs-ID. Bitte kontaktieren Sie den Support.');
    } else {
      let attempts = 0;
      const maxAttempts = 20;
      async function poll() {
        attempts++;
        try {
          const r = await fetch(CHECKOUT_WORKER + '/payment-status?id=' + encodeURIComponent(paymentId));
          const data = await r.json();
          if (data.videoTitle) videoTitle.textContent = data.videoTitle;
          if (data.status === 'paid') {
            const dl = CHECKOUT_WORKER + '/download?id=' + encodeURIComponent(paymentId);
            downloadBtn.href = dl;
            statusText.textContent = '✓ Zahlung bestätigt – Ihr Download ist bereit.';
            downloadBox.style.display = 'block';
            setTimeout(() => { window.location.href = dl; }, 1200);
            return;
          }
          if (['canceled','expired','failed'].includes(data.status)) {
            showError('Die Zahlung wurde nicht abgeschlossen (' + data.status + '). Bitte versuchen Sie es erneut.');
            return;
          }
          if (attempts >= maxAttempts) {
            showError('Zeitüberschreitung beim Warten auf die Zahlungsbestätigung. Bitte prüfen Sie Ihre E-Mail oder kontaktieren Sie den Support.');
            return;
          }
          setTimeout(poll, 2000);
        } catch (e) {
          showError('Fehler beim Abrufen des Zahlungsstatus: ' + e.message);
        }
      }
      poll();
    }
  </script>
</BaseLayout>
