---
import BaseLayout from '../../layouts/BaseLayout.astro';
const CHECKOUT_WORKER = 'https://stockvideo-checkout.rende.workers.dev';
---
<BaseLayout title="Bestellung erfolgreich - stockvideo.de">
  <main class="max-w-3xl mx-auto px-4 py-12">
    <div id="loading" class="text-center py-12">
      <div class="inline-block w-12 h-12 border-4 border-orange-500 border-t-transparent rounded-full animate-spin"></div>
      <p class="mt-4 text-gray-600">Bestellung wird verarbeitet...</p>
    </div>

    <div id="paid" class="hidden">
      <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
        <h1 class="text-2xl font-bold text-green-800 mb-2">Vielen Dank fuer deinen Kauf!</h1>
        <p class="text-green-700">Deine Zahlung wurde erfolgreich verarbeitet.</p>
      </div>

      <div class="bg-white border border-gray-200 rounded-lg p-6 mb-6">
        <h2 class="font-semibold text-lg mb-3">Bestelldetails</h2>
        <dl class="grid grid-cols-2 gap-y-2 text-sm">
          <dt class="text-gray-500">Bestellnummer</dt><dd id="dOrderId" class="font-mono">-</dd>
          <dt class="text-gray-500">Video</dt><dd id="dTitle">-</dd>
          <dt class="text-gray-500">Betrag</dt><dd id="dAmount">-</dd>
          <dt class="text-gray-500">Datum</dt><dd id="dPaidAt">-</dd>
        </dl>
      </div>

      <div class="bg-white border border-gray-200 rounded-lg p-6">
        <h2 class="font-semibold text-lg mb-3">Downloads</h2>
        <p class="text-sm text-gray-600 mb-4">Lade dein Video und die Lizenzurkunde herunter. Beide Links bleiben 7 Tage gueltig.</p>
        <div class="space-y-3">
          <a id="videoLink" href="#" class="block w-full text-center bg-orange-500 hover:bg-orange-600 text-white font-semibold py-3 rounded">
            Video herunterladen
          </a>
          <a id="pdfLink" href="#" target="_blank" class="block w-full text-center bg-gray-800 hover:bg-gray-900 text-white font-semibold py-3 rounded">
            Lizenzurkunde (PDF) herunterladen
          </a>
        </div>
      </div>
    </div>

    <div id="failed" class="hidden text-center py-12">
      <h1 class="text-2xl font-bold text-red-600 mb-2">Zahlung nicht erfolgreich</h1>
      <p class="text-gray-600 mb-4" id="failMsg">Deine Bestellung konnte nicht verarbeitet werden.</p>
      <a href="/" class="inline-block bg-orange-500 hover:bg-orange-600 text-white font-semibold py-2 px-4 rounded">Zur Startseite</a>
    </div>
  </main>

  <script is:inline define:vars={{ CHECKOUT_WORKER }}>
    const params = new URLSearchParams(window.location.search);
    const orderId = params.get('order') || params.get('orderId');
    const loading = document.getElementById('loading');
    const paid = document.getElementById('paid');
    const failed = document.getElementById('failed');

    if (!orderId) {
      loading.classList.add('hidden');
      failed.classList.remove('hidden');
      document.getElementById('failMsg').textContent = 'Keine Bestellnummer angegeben.';
    } else {
      pollOrder(0);
    }

    async function pollOrder(attempt) {
      try {
        const r = await fetch(CHECKOUT_WORKER + '/order/' + encodeURIComponent(orderId));
        if (!r.ok) throw new Error('Bestellung nicht gefunden');
        const order = await r.json();
        if (order.status === 'paid') {
          showPaid(order);
        } else if (['failed','expired','canceled'].includes(order.status)) {
          loading.classList.add('hidden');
          failed.classList.remove('hidden');
          document.getElementById('failMsg').textContent = 'Status: ' + order.status;
        } else if (attempt < 30) {
          setTimeout(() => pollOrder(attempt+1), 2000);
        } else {
          loading.classList.add('hidden');
          failed.classList.remove('hidden');
          document.getElementById('failMsg').textContent = 'Zeitueberschreitung. Bitte spaeter erneut pruefen.';
        }
      } catch(e) {
        loading.classList.add('hidden');
        failed.classList.remove('hidden');
        document.getElementById('failMsg').textContent = e.message;
      }
    }

    async function showPaid(order) {
      document.getElementById('dOrderId').textContent = order.id;
      document.getElementById('dTitle').textContent = (order.video && order.video.title) || '-';
      document.getElementById('dAmount').textContent = (order.amount || 0).toFixed(2) + ' ' + (order.currency || 'EUR');
      document.getElementById('dPaidAt').textContent = order.paidAt ? new Date(order.paidAt).toLocaleString('de-DE') : '-';

      const dr = await fetch(CHECKOUT_WORKER + '/download-url/' + encodeURIComponent(order.id));
      const dl = await dr.json();
      let videoUrl = dl.videoUrl;
      if (!videoUrl && order.video && order.video.id) {
        try {
          const vr = await fetch(CHECKOUT_WORKER + '/video/' + encodeURIComponent(order.video.id));
          if (vr.ok) {
            const v = await vr.json();
            videoUrl = v.url || v.videoUrl || (v.video && v.video.url);
          }
        } catch(_){}
      }
      document.getElementById('videoLink').href = videoUrl || '#';
      if (videoUrl) document.getElementById('videoLink').setAttribute('download','');
      document.getElementById('pdfLink').href = dl.pdfUrl || '#';
      loading.classList.add('hidden');
      paid.classList.remove('hidden');
    }
  </script>
</BaseLayout>
