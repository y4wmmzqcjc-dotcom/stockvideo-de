---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Zahlung erfolgreich — stockvideo.de">
  <main style="max-width: 640px; margin: 4rem auto; padding: 2rem; text-align: center;">
    <div style="font-size: 4rem;">✅</div>
    <h1 style="color: #fff;">Zahlung erfolgreich!</h1>
    <p id="statusText" style="color: #aaa;">Vielen Dank für Ihren Einkauf. Ihr Download wird vorbereitet…</p>

    <div id="downloadBox" style="display:none; margin-top: 2rem; padding: 2rem; background: rgba(20,115,230,0.1); border: 1px solid rgba(20,115,230,0.3); border-radius: 12px;">
      <h2 style="color: #22c55e; margin: 0 0 0.5rem 0;">Zahlung bestätigt!</h2>
      <p id="videoTitle" style="color: #ccc; margin: 0 0 1.5rem 0;"></p>
      <a id="downloadBtn" href="#" download style="display:inline-block; background: #1473e6; color:#fff; padding: 1rem 2rem; border-radius: 8px; text-decoration:none; font-weight:600;">⬇ Video herunterladen</a>
      <p style="color:#888; font-size: 0.9rem; margin-top: 1rem;">Der Download startet automatisch. Falls nicht, klicken Sie den Button erneut.</p>
    </div>

    <div id="errorBox" style="display:none; margin-top: 2rem; padding: 1.5rem; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); border-radius: 12px; color:#ef4444;">
      <p id="errorText"></p>
    </div>

    <p style="margin-top: 3rem;"><a href="/" style="color: #1473e6;">← Zurück zur Übersicht</a></p>
  </main>
</Layout>

<script is:inline>
(function() {
  var CHECKOUT_WORKER = 'https://stockvideo-checkout.rende.workers.dev';
  var params = new URLSearchParams(location.search);
  var paymentId = params.get('payment_id');
  var statusText = document.getElementById('statusText');
  var downloadBox = document.getElementById('downloadBox');
  var downloadBtn = document.getElementById('downloadBtn');
  var videoTitle = document.getElementById('videoTitle');
  var errorBox = document.getElementById('errorBox');
  var errorText = document.getElementById('errorText');

  function showError(msg) {
    statusText.style.display = 'none';
    errorBox.style.display = 'block';
    errorText.textContent = msg;
  }

  if (!paymentId || paymentId === '{id}' || paymentId === '%7Bid%7D') {
    showError('Fehlende Zahlungs-ID. Bitte kontaktieren Sie den Support.');
    return;
  }

  var attempts = 0;
  var MAX_ATTEMPTS = 20;

  function poll() {
    attempts++;
    fetch(CHECKOUT_WORKER + '/payment-status?id=' + encodeURIComponent(paymentId))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.error) { showError('Fehler: ' + data.error); return; }
        if (data.status === 'paid' && data.downloadUrl) {
          statusText.style.display = 'none';
          downloadBox.style.display = 'block';
          videoTitle.textContent = data.videoTitle || '';
          downloadBtn.href = data.downloadUrl;
          setTimeout(function() { window.location.href = data.downloadUrl; }, 800);
        } else if (data.status === 'open' || data.status === 'pending') {
          if (attempts < MAX_ATTEMPTS) {
            statusText.textContent = 'Warte auf Zahlungsbestätigung… (' + attempts + '/' + MAX_ATTEMPTS + ')';
            setTimeout(poll, 2000);
          } else {
            showError('Zeitüberschreitung. Bitte laden Sie die Seite neu.');
          }
        } else if (data.status === 'canceled' || data.status === 'expired' || data.status === 'failed') {
          showError('Zahlung ' + data.status + '. Bitte versuchen Sie es erneut.');
        } else {
          showError('Unbekannter Status: ' + (data.status || 'keine Antwort'));
        }
      })
      .catch(function(err) {
        if (attempts < MAX_ATTEMPTS) { setTimeout(poll, 2000); }
        else { showError('Netzwerkfehler: ' + err.message); }
      });
  }

  poll();
})();
</script>
