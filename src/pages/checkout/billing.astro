---
import BaseLayout from '../../layouts/BaseLayout.astro';
const CHECKOUT_WORKER = 'https://stockvideo-checkout.rende.workers.dev';
---
<BaseLayout title="Kasse. stockvideo.de">
  <main class="checkout-wrap">
    <div class="checkout-header">
      <h1>Rechnungsdaten</h1>
      <p>Bitte gib deine Rechnungsdaten ein. Mit diesen Daten erstellen wir deine Lizenzurkunde.</p>
    </div>

    <div class="order-summary">
      <div class="os-label">Video</div>
      <div class="os-title" id="sumTitle">. </div>
      <div class="os-divider"></div>
      <div class="os-price-row">
        <span class="os-label">Gesamtbetrag</span>
        <span class="os-price" id="sumPrice">. </span>
      </div>
    </div>

    <form id="billingForm" class="billing-form" autocomplete="on">
      <div class="row row-2">
        <label>
          <span>Vorname <em>*</em></span>
          <input name="firstName" required autocomplete="given-name" />
        </label>
        <label>
          <span>Nachname <em>*</em></span>
          <input name="lastName" required autocomplete="family-name" />
        </label>
      </div>

      <label>
        <span>Firma <small>(optional)</small></span>
        <input name="company" autocomplete="organization" />
      </label>

      <label>
        <span>Straße und Hausnummer <em>*</em></span>
        <input name="street" required autocomplete="street-address" />
      </label>

      <div class="row row-3">
        <label>
          <span>PLZ <em>*</em></span>
          <input name="zip" required autocomplete="postal-code" />
        </label>
        <label class="col-span-2">
          <span>Ort <em>*</em></span>
          <input name="city" required autocomplete="address-level2" />
        </label>
      </div>

      <label>
        <span>Land <em>*</em></span>
        <select name="country" required>
          <option value="DE">Deutschland</option>
          <option value="AT">Österreich</option>
          <option value="CH">Schweiz</option>
          <option value="LI">Liechtenstein</option>
          <option value="LU">Luxemburg</option>
          <option value="NL">Niederlande</option>
          <option value="BE">Belgien</option>
          <option value="FR">Frankreich</option>
          <option value="IT">Italien</option>
          <option value="ES">Spanien</option>
          <option value="OTHER">Anderes Land</option>
        </select>
      </label>

      <label>
        <span>USt-IdNr. <small>(optional)</small></span>
        <input name="vatId" placeholder="DE123456789" />
      </label>

      <label>
        <span>E-Mail <em>*</em></span>
        <input type="email" name="email" required autocomplete="email" />
        <small class="hint">Wir senden dir den Download-Link an diese Adresse.</small>
      </label>

      <label>
        <span>Projektname / Verwendungszweck <small>(optional)</small></span>
        <input name="projectName" placeholder="z. B. Imagefilm Mustermann GmbH" />
        <small class="hint">Erscheint auf der Lizenzurkunde.</small>
      </label>

      <label class="consent-label">
        <input type="checkbox" name="widerrufConsent" id="widerrufConsent" required />
        <span>
          Ich stimme ausdrücklich zu, dass mit der Ausführung des Vertrages vor Ablauf der Widerrufsfrist begonnen wird. Mir ist bekannt, dass mein <a href="/agb#widerrufsrecht" target="_blank" rel="noopener">Widerrufsrecht</a> mit Beginn des Downloads erlischt (§ 356 Abs. 5 BGB).
        </span>
      </label>

      <label class="consent-label">
        <input type="checkbox" name="agbConsent" id="agbConsent" required />
        <span>
          Ich akzeptiere die <a href="/agb" target="_blank" rel="noopener">AGB</a> und habe die <a href="/datenschutz" target="_blank" rel="noopener">Datenschutzerklärung</a> gelesen.
        </span>
      </label>

      <div id="errBox" class="err-box" hidden></div>

      <button type="submit" id="payBtn" class="pay-btn">Zahlungspflichtig bestellen</button>
      <p class="trust-note">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Sichere Zahlung via Mollie · Kreditkarte, PayPal, SOFORT, Klarna
      </p>
    </form>
  </main>

  <style>
    .checkout-wrap {
      max-width: 640px;
      margin: 0 auto;
      padding: 48px 20px 80px;
    }
    .checkout-header h1 {
      font-size: 32px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 8px;
      letter-spacing: -0.02em;
    }
    .checkout-header p {
      color: #9a9a9a;
      font-size: 15px;
      margin-bottom: 32px;
    }
    .order-summary {
      background: #222;
      border: 1px solid #3a3a3a;
      border-radius: 12px;
      padding: 20px 24px;
      margin-bottom: 28px;
    }
    .os-label {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #8a8a8a;
      font-weight: 600;
    }
    .os-title {
      font-size: 18px;
      font-weight: 600;
      color: #fff;
      margin-top: 4px;
    }
    .os-divider {
      height: 1px;
      background: #3a3a3a;
      margin: 16px 0;
    }
    .os-price-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .os-price {
      font-size: 24px;
      font-weight: 700;
      color: #1473e6;
    }
    .billing-form {
      background: #222;
      border: 1px solid #3a3a3a;
      border-radius: 12px;
      padding: 28px;
      display: flex;
      flex-direction: column;
      gap: 18px;
    }
    .billing-form label {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .billing-form label > span {
      font-size: 13px;
      font-weight: 600;
      color: #c8c8c8;
    }
    .billing-form label > span em {
      color: #1473e6;
      font-style: normal;
    }
    .billing-form label > span small {
      color: #8a8a8a;
      font-weight: 400;
    }
    .billing-form input,
    .billing-form select {
      background: #1b1b1b;
      border: 1px solid #3a3a3a;
      border-radius: 8px;
      padding: 11px 14px;
      font-size: 15px;
      color: #fff;
      font-family: inherit;
      transition: border-color 0.15s, background 0.15s;
    }
    .billing-form input:hover,
    .billing-form select:hover {
      border-color: #4a4a4a;
    }
    .billing-form input:focus,
    .billing-form select:focus {
      outline: none;
      border-color: #1473e6;
      background: #232323;
    }
    .billing-form input::placeholder {
      color: #5a5a5a;
    }
    .billing-form .hint {
      font-size: 12px;
      color: #7a7a7a;
    }
    .consent-label {
      flex-direction: row !important;
      align-items: flex-start;
      gap: 10px !important;
      padding: 12px 14px;
      background: #1b1b1b;
      border: 1px solid #3a3a3a;
      border-radius: 8px;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
    }
    .consent-label:hover {
      border-color: #4a4a4a;
      background: #1f1f1f;
    }
    .consent-label input[type="checkbox"] {
      flex-shrink: 0;
      width: 18px;
      height: 18px;
      margin-top: 2px;
      accent-color: #1473e6;
      cursor: pointer;
    }
    .consent-label > span {
      font-size: 13px !important;
      font-weight: 400 !important;
      color: #c8c8c8 !important;
      line-height: 1.5;
    }
    .consent-label a {
      color: #1473e6;
      text-decoration: underline;
    }
    .consent-label a:hover {
      color: #4d94ed;
    }
    .row {
      display: grid;
      gap: 14px;
    }
    .row-2 { grid-template-columns: 1fr 1fr; }
    .row-3 { grid-template-columns: 1fr 2fr; gap: 14px; }
    .col-span-2 { grid-column: span 1; }
    @media (max-width: 520px) {
      .row-2, .row-3 { grid-template-columns: 1fr; }
    }
    .err-box {
      background: rgba(220, 38, 38, 0.12);
      border: 1px solid rgba(220, 38, 38, 0.35);
      color: #fca5a5;
      padding: 12px 14px;
      border-radius: 8px;
      font-size: 14px;
    }
    .pay-btn {
      background: #1473e6;
      border: none;
      color: #fff;
      font-size: 16px;
      font-weight: 600;
      padding: 14px 20px;
      border-radius: 10px;
      margin-top: 6px;
      transition: background 0.15s, transform 0.05s;
    }
    .pay-btn:hover { background: #0d66d0; }
    .pay-btn:active { transform: translateY(1px); }
    .pay-btn:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }
    .trust-note {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-size: 12px;
      color: #7a7a7a;
      margin-top: 2px;
    }
  </style>

  <script is:inline define:vars={{ CHECKOUT_WORKER }}>
    const params = new URLSearchParams(window.location.search);
    const videoId = params.get('id') || '';
    const videoTitle = params.get('title') || '';
    const price = parseFloat(params.get('price') || '0');
    const slug = params.get('slug') || '';

    if (!videoId || !videoTitle || !price) {
      window.location.href = '/';
    }

    document.getElementById('sumTitle').textContent = videoTitle;
    document.getElementById('sumPrice').textContent = price.toFixed(2).replace('.', ',') + ' €';

    const form = document.getElementById('billingForm');
    const errBox = document.getElementById('errBox');
    const payBtn = document.getElementById('payBtn');

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      errBox.hidden = true;
      payBtn.disabled = true;
      payBtn.textContent = 'Bestellung wird erstellt …';

      const fd = new FormData(form);
      const billing = {};
      for (const [k,v] of fd.entries()) billing[k] = v;
      const projectName = billing.projectName || '';
      delete billing.projectName;
      // Consent-Felder gehören nicht in die Rechnungsadresse
      delete billing.widerrufConsent;
      delete billing.agbConsent;

      // Doppelte Sicherheitsprüfung (zusätzlich zum required-Attribut)
      if (!form.querySelector('#widerrufConsent').checked || !form.querySelector('#agbConsent').checked) {
        errBox.textContent = 'Bitte bestätige beide Pflichtangaben (Widerruf und AGB).';
        errBox.hidden = false;
        payBtn.disabled = false;
        payBtn.textContent = 'Zahlungspflichtig bestellen';
        return;
      }

      try {
        const r = await fetch(CHECKOUT_WORKER + '/create-order', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({ videoId, videoTitle, videoUrl: '', price, billing, projectName })
        });
        const data = await r.json();
        if (!r.ok || !data.checkoutUrl) throw new Error(data.error || 'Bestellung konnte nicht erstellt werden');
        window.location.href = data.checkoutUrl;
      } catch(err) {
        errBox.textContent = 'Fehler: ' + err.message;
        errBox.hidden = false;
        payBtn.disabled = false;
        payBtn.textContent = 'Zahlungspflichtig bestellen';
      }
    });
  </script>
</BaseLayout>
