---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import VideoCard from '../../components/VideoCard.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allVideos = await getCollection('videos');
  const categories = [...new Set(allVideos.map(v => v.data.category))];

  // All known categories (including ones without videos yet)
  const allCategories = [
    'business', 'natur', 'lifestyle', 'architektur', 'technologie', 'sport',
    ...categories,
  ];
  const uniqueCategories = [...new Set(allCategories)];

  return uniqueCategories.map(category => ({
    params: { category },
    props: {
      videos: allVideos.filter(v => v.data.category === category),
    },
  }));
}

const { category } = Astro.params;
const { videos } = Astro.props;

const categoryLabels: Record<string, string> = {
  business:    'Business',
  natur:       'Natur & Landschaft',
  lifestyle:   'Lifestyle',
  architektur: 'Architektur',
  technologie: 'Technologie',
  sport:       'Sport',
};

const categoryDescriptions: Record<string, string> = {
  business:    'Professionelle Business-Videos: Meetings, Büroalltag, Teams und Unternehmenskultur in 4K.',
  natur:       'Natur- und Landschaftsaufnahmen aus Deutschland: Küsten, Berge, Wälder und Drohnenflüge in 4K.',
  lifestyle:   'Authentische Lifestyle-Aufnahmen: Alltag, Menschen, Stimmungen — lizenzfrei und sofort verfügbar.',
  architektur: 'Architekturvideos: Moderne Gebäude, historische Bauten und Stadtlandschaften in hochwertiger 4K-Qualität.',
  technologie: 'Technologie-Videos: Digitale Arbeitswelt, Devices, Software und Innovation in professioneller Qualität.',
  sport:       'Sport- und Bewegungsvideos: Action, Training, Outdoor und Fitness in dynamischer 4K-Qualität.',
};

const label = categoryLabels[category] ?? category;
const description = categoryDescriptions[category] ?? `${label}-Videos lizenzieren auf stockvideo.de`;

const breadcrumbs = [
  { href: '/', label: 'Start' },
  { href: '/kategorie', label: 'Kategorien' },
  { href: `/kategorie/${category}`, label: label },
];
---

<BaseLayout
  title={`${label} Stock-Videos — stockvideo.de`}
  description={description}
>
  <Navbar />
  <main>
    <!-- Breadcrumb -->
    <div class="breadcrumb-bar">
      <div class="container">
        <nav aria-label="Breadcrumb">
          <ol class="breadcrumb">
            {breadcrumbs.map((crumb, i) => (
              <li class="breadcrumb__item">
                {i < breadcrumbs.length - 1
                  ? <><a href={crumb.href} class="breadcrumb__link">{crumb.label}</a><span aria-hidden="true"> / </span></>
                  : <span aria-current="page">{crumb.label}</span>
                }
              </li>
            ))}
          </ol>
        </nav>
      </div>
    </div>

    <!-- Header -->
    <section class="category-header section" style="padding-bottom: 32px;">
      <div class="container">
        <h1>{label}</h1>
        <p style="margin-top: 10px; max-width: 560px;">{description}</p>
        <p style="margin-top: 8px; font-size: 0.875rem; color: var(--color-text-faint);">
          {videos.length} {videos.length === 1 ? 'Video' : 'Videos'} verfügbar
        </p>
      </div>
    </section>

    <!-- Grid -->
    <section class="section" style="padding-top: 0;">
      <div class="container">
        {videos.length > 0 ? (
          <div class="grid-4">
            {videos.map((video) => (
              <VideoCard
                slug={video.id}
                title={video.data.title}
                description={video.data.description}
                category={video.data.category}
                resolution={video.data.resolution}
                duration={video.data.duration}
                thumbnail={video.data.thumbnail}
                price={video.data.price}
                featured={video.data.featured}
              />
            ))}
          </div>
        ) : (
          <div class="empty-state">
            <div class="empty-state__icon">🎬</div>
            <h2>Noch keine Videos in dieser Kategorie</h2>
            <p>Wir arbeiten daran, unsere Bibliothek zu erweitern. Bald verfügbar!</p>
            <a href="/" class="btn btn-primary" style="margin-top: 20px;">Zurück zur Startseite</a>
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
.breadcrumb-bar {
  background: var(--color-bg-2);
  border-bottom: 1px solid var(--color-border);
  padding: 10px 0;
}
.breadcrumb {
  display: flex;
  gap: 4px;
  align-items: center;
  flex-wrap: wrap;
}
.breadcrumb__item {
  display: flex;
  align-items: center;
  font-size: 0.8125rem;
  color: var(--color-text-faint);
}
.breadcrumb__link {
  color: var(--color-text-muted);
  transition: color var(--transition);
}
.breadcrumb__link:hover { color: var(--color-accent); }

.empty-state {
  text-align: center;
  padding: 80px 24px;
}
.empty-state__icon { font-size: 3rem; margin-bottom: 16px; }
.empty-state h2 { margin-bottom: 8px; }
.empty-state p { color: var(--color-text-muted); }
</style>
