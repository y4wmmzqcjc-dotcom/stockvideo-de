---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Topbar from '../../components/Topbar.astro';
import Footer from '../../components/Footer.astro';
import articles from '../../data/articles.json';

export function getStaticPaths() {
  return articles
    .filter((a) => a.status === 'published')
    .map((article) => ({
      params: { slug: article.slug },
      props: { article },
    }));
}

const { article } = Astro.props;
const allArticles = articles.filter((a) => a.status === 'published');

// Related articles from internalLinks
const relatedArticles = (article.internalLinks || [])
  .map((id) => allArticles.find((a) => a.id === id))
  .filter(Boolean)
  .slice(0, 3);

// Hero image from making-of photos
const heroImage = article.heroImage || '/images/making-of/making-of-01.jpg';
const inlineImages = article.inlineImages || [];

// Matching videos
import videosData from '../../data/videos.json';
const sidebarVideos = (videosData || []).slice(0, 3);

// Build TOC from sections
const toc = (article.sections || []).map((s, i) => ({
  id: 'section-' + (i + 1),
  text: s.heading,
}));

// JSON-LD structured data
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.seoTitle || article.title,
  description: article.metaDescription,
  image: {
    '@type': 'ImageObject',
    url: 'https://stockvideo.de' + heroImage,
    width: 1920,
    height: 640,
  },
  author: {
    '@type': 'Person',
    name: 'Timo Rende',
    url: 'https://stockvideo.de/uber-uns',
  },
  publisher: {
    '@type': 'Organization',
    name: 'stockvideo.de',
    url: 'https://stockvideo.de',
    logo: {
      '@type': 'ImageObject',
      url: 'https://stockvideo.de/favicon.svg',
    },
  },
  datePublished: article.publishDate,
  dateModified: article.publishDate,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://stockvideo.de/wissen/' + article.slug + '/',
  },
  contentLocation: article.imageGeoCity
    ? {
        '@type': 'Place',
        name: article.imageGeoCity,
        geo: {
          '@type': 'GeoCoordinates',
          latitude: article.imageGeoLat,
          longitude: article.imageGeoLng,
        },
      }
    : undefined,
};

// FAQ schema from sections
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: (article.sections || [])
    .filter((s) => s.heading && s.heading.includes('?'))
    .map((s) => ({
      '@type': 'Question',
      name: s.heading,
      acceptedAnswer: {
        '@type': 'Answer',
        text: s.paragraphs ? s.paragraphs[0] : '',
      },
    })),
};

// Canonical URL
const canonicalUrl = 'https://stockvideo.de/wissen/' + article.slug + '/';

// Find inline image insertion points (after section 1 and section 3)
function getInlineImage(index) {
  if (inlineImages && inlineImages[index]) {
    return '/images/making-of/' + inlineImages[index];
  }
  return null;
}
---

<BaseLayout
  title={article.seoTitle || article.title}
  description={article.metaDescription}
>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={article.seoTitle || article.title} />
    <meta property="og:description" content={article.metaDescription} />
    <meta property="og:image" content={'https://stockvideo.de' + heroImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="stockvideo.de" />
    <meta property="article:published_time" content={article.publishDate} />
    <meta property="article:author" content="Timo Rende" />
    <meta property="article:section" content={article.category} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={article.seoTitle || article.title} />
    <meta name="twitter:description" content={article.metaDescription} />
    <meta name="twitter:image" content={'https://stockvideo.de' + heroImage} />
    {article.imageGeoLat && (
      <meta name="geo.position" content={`${article.imageGeoLat};${article.imageGeoLng}`} />
    )}
    {article.imageGeoCity && <meta name="geo.placename" content={article.imageGeoCity} />}
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    {faqSchema.mainEntity.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )}
  </Fragment>

  <Topbar />

  <!-- Breadcrumbs -->
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <div class="breadcrumbs-inner">
      <a href="/">Startseite</a>
      <span class="sep">/</span>
      <a href="/wissen/">Wissen</a>
      <span class="sep">/</span>
      <span class="current">{article.title}</span>
    </div>
  </nav>

  <!-- Hero with Making-Of Photo -->
  <div class="article-hero">
    <img
      src={heroImage}
      alt={article.imageAlt || article.title}
      class="hero-img"
      loading="eager"
      width="1920"
      height="640"
    />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <span class="hero-category" style={`background:${article.categoryColor || '#3B82F6'}`}>
        {article.category}
      </span>
    </div>
  </div>

  <!-- Article Wrap -->
  <div class="article-wrap">
    <div class="article-grid">

      <!-- Main Content -->
      <article class="article-content">
        <h1>{article.title}</h1>

        <div class="article-meta">
          <div class="author-info">
            <span class="author-avatar">TR</span>
            <div>
              <span class="author-name">Timo Rende</span>
              <span class="meta-details">
                {article.readTime} Min. Lesezeit &middot; {new Date(article.publishDate).toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' })}
                {article.imageGeoCity && (<span> &middot; {article.imageGeoCity}</span>)}
              </span>
            </div>
          </div>
        </div>

        {article.intro && (
          <p class="article-intro">{article.intro}</p>
        )}

        <div class="article-body">
          {(article.sections || []).map((section, idx) => (
            <section>
              <h2 id={`section-${idx + 1}`}>{section.heading}</h2>
              {(section.paragraphs || []).map((p) => (
                <p set:html={p} />
              ))}
              {/* Inline Making-Of image after sections 1 and 3 */}
              {idx === 0 && getInlineImage(0) && (
                <figure class="inline-figure">
                  <img
                    src={getInlineImage(0)}
                    alt={`Making-Of: ${article.title}`}
                    loading="lazy"
                    width="800"
                    height="450"
                  />
                  <figcaption>Einblick in unsere Produktion</figcaption>
                </figure>
              )}
              {idx === 2 && getInlineImage(1) && (
                <figure class="inline-figure">
                  <img
                    src={getInlineImage(1)}
                    alt={`Behind the Scenes: ${article.title}`}
                    loading="lazy"
                    width="800"
                    height="450"
                  />
                  <figcaption>Hinter den Kulissen bei stockvideo.de</figcaption>
                </figure>
              )}
              {idx === 4 && getInlineImage(2) && (
                <figure class="inline-figure">
                  <img
                    src={getInlineImage(2)}
                    alt={`Produktion: ${article.title}`}
                    loading="lazy"
                    width="800"
                    height="450"
                  />
                  <figcaption>So arbeiten wir bei stockvideo.de</figcaption>
                </figure>
              )}
            </section>
          ))}
        </div>

        {article.conclusion && (
          <div class="article-conclusion">
            <h2>Fazit</h2>
            <p>{article.conclusion}</p>
          </div>
        )}

        <!-- Tags -->
        <div class="article-tags">
          <span class="tag-label">Themen:</span>
          <a href={`/wissen/?q=${encodeURIComponent(article.keyphrase)}`} class="tag">{article.keyphrase}</a>
          <a href={`/wissen/?q=${encodeURIComponent(article.category)}`} class="tag">{article.category}</a>
        </div>

        <!-- Share -->
        <div class="article-share">
          <span class="share-label">Teilen:</span>
          <button class="share-btn" onclick="navigator.clipboard.writeText(window.location.href).then(()=>this.textContent='Kopiert!')">Link kopieren</button>
          <a class="share-btn" href={`mailto:?subject=${encodeURIComponent(article.title)}&body=${encodeURIComponent(canonicalUrl)}`}>Per E-Mail</a>
          <a class="share-btn" href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(canonicalUrl)}&text=${encodeURIComponent(article.title)}`} target="_blank" rel="noopener noreferrer">Twitter</a>
          <a class="share-btn" href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonicalUrl)}`} target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="sidebar">
        <!-- TOC -->
        <div class="sidebar-box toc-box">
          <h3>Inhalt</h3>
          <nav class="toc-nav">
            <ul>
              {toc.map((item) => (
                <li>
                  <a href={`#${item.id}`} class="toc-link">{item.text}</a>
                </li>
              ))}
            </ul>
          </nav>
        </div>

        <!-- Passende Videos -->
        <div class="sidebar-box videos-box">
          <h3>Passende Videos</h3>
          <div class="sidebar-videos">
            {sidebarVideos.map((video) => (
              <a href={`/video/${video.slug}/`} class="sidebar-video-card">
                <img
                  src={video.thumbnail}
                  alt={video.title}
                  loading="lazy"
                  width="320"
                  height="180"
                />
                <span class="video-card-title">{video.title}</span>
              </a>
            ))}
          </div>
        </div>

        <!-- CTA Box -->
        <div class="sidebar-box cta-box">
          <h3>Videos entdecken</h3>
          <p>Lizenzfreie 4K-Videos für Ihr nächstes Projekt. Sofort einsatzbereit.</p>
          <a href="/" class="cta-button">Jetzt stöbern</a>
        </div>
      </aside>
    </div>

    <!-- Related Articles -->
    {relatedArticles.length > 0 && (
      <section class="related-section">
        <h2>Weiterlesen</h2>
        <div class="related-grid">
          {relatedArticles.map((rel) => (
            <a href={`/wissen/${rel.slug}/`} class="related-card">
              <img
                src={rel.heroImage || '/images/making-of/making-of-01.jpg'}
                alt={rel.title}
                loading="lazy"
                width="400"
                height="225"
              />
              <div class="related-card-body">
                <span class="related-category" style={`color:${rel.categoryColor || '#3B82F6'}`}>{rel.category}</span>
                <h3>{rel.title}</h3>
                <span class="related-meta">{rel.readTime} Min. Lesezeit</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>

  <Footer />
</BaseLayout>

<style>
  /* Breadcrumbs */
  .breadcrumbs {
    background: #111;
    border-bottom: 1px solid #222;
    padding: 12px 0;
  }
  .breadcrumbs-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    font-size: 0.85rem;
    color: #888;
  }
  .breadcrumbs a {
    color: #aaa;
    text-decoration: none;
  }
  .breadcrumbs a:hover {
    color: #fff;
  }
  .breadcrumbs .sep {
    margin: 0 8px;
    color: #555;
  }
  .breadcrumbs .current {
    color: #ccc;
  }

  /* Hero */
  .article-hero {
    position: relative;
    width: 100%;
    aspect-ratio: 21 / 7;
    max-height: 480px;
    overflow: hidden;
    background: #0d0d0d;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(13, 13, 13, 0) 40%,
      rgba(13, 13, 13, 0.7) 75%,
      rgba(13, 13, 13, 1) 100%
    );
  }
  .hero-content {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 1280px;
    padding: 0 24px;
    box-sizing: border-box;
  }
  .hero-category {
    display: inline-block;
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* Article Wrap */
  .article-wrap {
    max-width: 1280px;
    margin: -40px auto 0;
    padding: 0 24px 60px;
    position: relative;
    z-index: 2;
  }

  /* Grid */
  .article-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 48px;
    align-items: start;
  }

  /* Article Content */
  .article-content {
    min-width: 0;
  }
  .article-content h1 {
    font-size: 2.2rem;
    font-weight: 800;
    line-height: 1.2;
    color: #fff;
    margin: 0 0 20px;
  }

  /* Meta */
  .article-meta {
    display: flex;
    align-items: center;
    margin-bottom: 28px;
    padding-bottom: 20px;
    border-bottom: 1px solid #222;
  }
  .author-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .author-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #3B82F6, #8B5CF6);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.85rem;
    color: #fff;
    flex-shrink: 0;
  }
  .author-name {
    display: block;
    font-weight: 600;
    color: #fff;
    font-size: 0.95rem;
  }
  .meta-details {
    display: block;
    color: #888;
    font-size: 0.85rem;
    margin-top: 2px;
  }

  /* Intro */
  .article-intro {
    font-size: 1.15rem;
    line-height: 1.7;
    color: #ccc;
    margin-bottom: 32px;
    border-left: 3px solid #3B82F6;
    padding-left: 16px;
  }

  /* Body */
  .article-body h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
    margin: 40px 0 16px;
    scroll-margin-top: 100px;
  }
  .article-body p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #bbb;
    margin-bottom: 16px;
  }

  /* Inline figures */
  .inline-figure {
    margin: 32px 0;
    border-radius: 12px;
    overflow: hidden;
    background: #1a1a1a;
  }
  .inline-figure img {
    width: 100%;
    height: auto;
    display: block;
  }
  .inline-figure figcaption {
    padding: 10px 16px;
    font-size: 0.85rem;
    color: #888;
    text-align: center;
  }

  /* Conclusion */
  .article-conclusion {
    margin-top: 40px;
    padding: 24px;
    background: #1a1a1a;
    border-radius: 12px;
    border-left: 4px solid #3B82F6;
  }
  .article-conclusion h2 {
    font-size: 1.3rem;
    color: #fff;
    margin: 0 0 12px;
  }
  .article-conclusion p {
    color: #bbb;
    line-height: 1.7;
    margin: 0;
  }

  /* Tags */
  .article-tags {
    margin-top: 32px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }
  .tag-label {
    color: #888;
    font-size: 0.9rem;
    margin-right: 4px;
  }
  .tag {
    background: #1a1a1a;
    color: #ccc;
    padding: 5px 14px;
    border-radius: 20px;
    font-size: 0.8rem;
    text-decoration: none;
    border: 1px solid #333;
    transition: border-color 0.2s;
  }
  .tag:hover {
    border-color: #3B82F6;
    color: #fff;
  }

  /* Share */
  .article-share {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid #222;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }
  .share-label {
    color: #888;
    font-size: 0.9rem;
    margin-right: 4px;
  }
  .share-btn {
    background: #1a1a1a;
    color: #ccc;
    padding: 6px 14px;
    border-radius: 8px;
    font-size: 0.85rem;
    text-decoration: none;
    border: 1px solid #333;
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.2s;
  }
  .share-btn:hover {
    border-color: #3B82F6;
    color: #fff;
  }

  /* Sidebar */
  .sidebar {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .sidebar-box {
    background: #151515;
    border: 1px solid #222;
    border-radius: 12px;
    padding: 20px;
  }
  .sidebar-box h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 14px;
  }

  /* TOC */
  .toc-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc-nav li {
    margin-bottom: 6px;
  }
  .toc-link {
    color: #888;
    text-decoration: none;
    font-size: 0.85rem;
    line-height: 1.4;
    display: block;
    padding: 4px 0 4px 12px;
    border-left: 2px solid transparent;
    transition: all 0.2s;
  }
  .toc-link:hover,
  .toc-link.active {
    color: #fff;
    border-left-color: #3B82F6;
  }

  /* Sidebar Videos */
  .sidebar-videos {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .sidebar-video-card {
    display: flex;
    gap: 10px;
    align-items: center;
    text-decoration: none;
    color: #ccc;
    padding: 6px;
    border-radius: 8px;
    transition: background 0.2s;
  }
  .sidebar-video-card:hover {
    background: #1a1a1a;
  }
  .sidebar-video-card img {
    width: 100px;
    height: 56px;
    object-fit: cover;
    border-radius: 6px;
    flex-shrink: 0;
    background: #222;
  }
  .video-card-title {
    font-size: 0.85rem;
    line-height: 1.3;
  }

  /* CTA Box */
  .cta-box {
    background: linear-gradient(135deg, #1a1a2e, #16213e);
    border-color: #1a3a5c;
    text-align: center;
  }
  .cta-box p {
    color: #aaa;
    font-size: 0.85rem;
    margin: 0 0 14px;
    line-height: 1.5;
  }
  .cta-button {
    display: inline-block;
    background: #3B82F6;
    color: #fff;
    padding: 10px 24px;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
  }
  .cta-button:hover {
    background: #2563eb;
  }

  /* Related Section */
  .related-section {
    margin-top: 60px;
    padding-top: 40px;
    border-top: 1px solid #222;
  }
  .related-section h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 24px;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .related-card {
    background: #151515;
    border: 1px solid #222;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }
  .related-card:hover {
    border-color: #333;
    transform: translateY(-2px);
  }
  .related-card img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
    background: #222;
  }
  .related-card-body {
    padding: 16px;
  }
  .related-category {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .related-card h3 {
    font-size: 0.95rem;
    font-weight: 600;
    color: #fff;
    margin: 6px 0;
    line-height: 1.3;
  }
  .related-meta {
    font-size: 0.8rem;
    color: #888;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .article-grid {
      grid-template-columns: 1fr;
    }
    .sidebar {
      position: static;
    }
    .related-grid {
      grid-template-columns: 1fr;
    }
    .article-hero {
      aspect-ratio: 16 / 9;
    }
    .article-content h1 {
      font-size: 1.6rem;
    }
  }
</style>

<script>
  // TOC active state on scroll
  document.addEventListener('DOMContentLoaded', () => {
    const links = document.querySelectorAll('.toc-link');
    const headings = document.querySelectorAll('.article-body h2[id]');
    if (!headings.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            links.forEach((l) => l.classList.remove('active'));
            const active = document.querySelector(`.toc-link[href="#${entry.target.id}"]`);
            if (active) active.classList.add('active');
          }
        });
      },
      { rootMargin: '-100px 0px -70% 0px' }
    );
    headings.forEach((h) => observer.observe(h));
  });
</script>
