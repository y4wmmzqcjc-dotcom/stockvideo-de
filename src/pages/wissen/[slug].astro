---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Topbar from '../../components/Topbar.astro';
import Footer from '../../components/Footer.astro';
import articles from '../../data/articles.json';
import videos from '../../data/videos.json';

export function getStaticPaths() {
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

const { article } = Astro.props;
const relatedArticles = articles.filter(a => article.internalLinks.includes(a.id)).slice(0, 3);
const relatedVideos = videos.slice(0, 3);

// Generate table of contents from article content
const headings = (article.sections || []).map((s: any) => {
  const text = s.heading;
  const id = text.toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]/g, '');
  return { text, id };
});

// Structured data - JSON-LD
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.seoTitle,
  description: article.metaDescription,
  image: article.imageUrl,
  datePublished: article.datePublished || new Date().toISOString(),
  dateModified: new Date().toISOString(),
  author: {
    '@type': 'Person',
    name: 'Timo Rende'
  }
};

// Tags from article or defaults
const tags = article.tags || [article.category];
---

<BaseLayout title={article.seoTitle} description={article.metaDescription}>
  <div class="page-wrapper">
    <Topbar />

    <div class="breadcrumbs">
      <a href="/">Startseite</a> / <a href="/wissen">Wissen</a> / {article.title}
    </div>

    <!-- Fullwidth Hero -->
    <div class="article-hero" style={`background: linear-gradient(135deg, ${article.categoryColor || '#1a1a2e'}cc, ${article.categoryColor || '#16213e'}88, #0f3460)`}>
      <div class="hero-emoji">{article.categoryEmoji || 'ð'}</div>
    </div>

    <!-- Content overlapping hero -->
    <div class="article-wrap">
      <div class="article-main">
        <div class="article-content">
          <div class="article-cat" style={`color: ${article.categoryColor || '#2563eb'}`}>{article.category}</div>
          <h1 class="article-title">{article.title}</h1>
          <div class="article-meta">
            <div class="author">
              <div class="author-avatar">TR</div>
              <span>Timo Rende</span>
            </div>
            <span>ð {article.readTime} Min. Lesezeit</span>
            <span>ð 10. April 2026</span>
          </div>

          {article.intro && (
            <p class="intro-paragraph">{article.intro}</p>
          )}

          <div class="article-body">
          {(article.sections || []).map((section: any) => (
            <section>
              <h2 id={section.heading.toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]/g, '')}>{section.heading}</h2>
              {section.paragraphs.map((p: string) => (
                <p set:html={p} />
              ))}
            </section>
          ))}
        </div>

          {article.conclusion && (
            <p class="conclusion-paragraph">{article.conclusion}</p>
          )}

          {relatedArticles.length > 0 && (
            <section class="internal-links-section">
              <h2>WeiterfÃ¼hrende Artikel</h2>
              <ul class="internal-links-list">
                {relatedArticles.map(related => (
                  <li>
                    <a href={`/wissen/${related.slug}`}>{related.title}</a>
                  </li>
                ))}
              </ul>
            </section>
          )}

          <div class="article-tags">
            {tags.map((tag: string) => (
              <a href={`/wissen?tag=${tag}`} class="tag">{tag}</a>
            ))}
          </div>

          <div class="share-row">
            <button class="share-btn" data-action="copy">ð Link kopieren</button>
            <button class="share-btn" data-action="email">ð§ Per E-Mail teilen</button>
            <button class="share-btn" data-action="twitter">ð Twitter</button>
            <button class="share-btn" data-action="linkedin">ð¼ LinkedIn</button>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="article-sidebar">
          {headings.length > 0 && (
            <div class="sidebar-section">
              <h3 class="sidebar-title">Inhaltsverzeichnis</h3>
              <nav class="toc-nav">
                {headings.map((heading: any) => (
                  <a href={`#${heading.id}`} class="toc-link">{heading.text}</a>
                ))}
              </nav>
            </div>
          )}

          <div class="sidebar-section">
            <h3 class="sidebar-title">Passende Videos</h3>
            {relatedVideos.map(video => (
              <a href={`/video/${video.slug}`} class="video-card-sm">
                <div class="video-thumb-placeholder" style={`background: linear-gradient(135deg, ${article.categoryColor || '#2563eb'}40, ${article.categoryColor || '#2563eb'}20)`}>â¶</div>
                <div class="video-card-info">
                  <div class="video-card-title">{video.title}</div>
                  <div class="video-card-price">ab 29 â¬</div>
                </div>
              </a>
            ))}
          </div>

          <div class="cta-box">
            <h3>Videos entdecken</h3>
            <p>Finden Sie das perfekte Stockvideo fÃ¼r Ihr Projekt.</p>
            <a href="/" class="cta-btn">Jetzt durchstÃ¶bern â</a>
          </div>
        </aside>
      </div>

      <!-- Related Articles -->
      {relatedArticles.length > 0 && (
        <div class="related-articles">
          <h2 class="related-title">Verwandte Artikel</h2>
          <div class="related-grid">
            {relatedArticles.map(related => (
              <a href={`/wissen/${related.slug}`} class="related-card">
                <div class="img-placeholder" style={`background: linear-gradient(135deg, ${related.categoryColor || '#2563eb'}40, ${related.categoryColor || '#2563eb'}20)`}>
                  <span>{related.categoryEmoji || 'ð'}</span>
                </div>
                <div class="related-card-body">
                  <div class="related-card-cat">{related.category}</div>
                  <div class="related-card-title">{related.title}</div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>

    <Footer />
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <script>
    // Share functionality
    document.querySelectorAll('.share-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const action = (btn as HTMLElement).dataset.action;
        const url = window.location.href;
        const title = document.title;
        if (action === 'copy') {
          navigator.clipboard.writeText(url).then(() => {
            (btn as HTMLElement).textContent = 'â Kopiert!';
            setTimeout(() => { (btn as HTMLElement).textContent = 'ð Link kopieren'; }, 2000);
          });
        } else if (action === 'email') {
          window.open(`mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(url)}`);
        } else if (action === 'twitter') {
          window.open(`https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`, '_blank');
        } else if (action === 'linkedin') {
          window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`, '_blank');
        }
      });
    });

    // TOC active state on scroll
    const tocLinks = document.querySelectorAll('.toc-link');
    if (tocLinks.length > 0) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            tocLinks.forEach(l => l.classList.remove('active'));
            const activeLink = document.querySelector(`.toc-link[href="#${entry.target.id}"]`);
            if (activeLink) activeLink.classList.add('active');
          }
        });
      }, { rootMargin: '-80px 0px -60% 0px' });

      document.querySelectorAll('.article-body h2').forEach(h2 => {
        const text = h2.textContent || '';
        const id = text.toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]/g, '');
        h2.id = id;
        observer.observe(h2);
      });
    }
  </script>
</BaseLayout>

<style>
  /* === BASE === */
  .page-wrapper {
    min-height: 100vh;
    background: #0d0d0d;
    color: #e1e1e1;
    font-family: 'Inter', 'Source Sans 3', sans-serif;
  }

  /* === BREADCRUMBS === */
  .breadcrumbs {
    padding: 16px 40px;
    font-size: 13px;
    color: #666;
    border-bottom: 1px solid #151515;
  }
  .breadcrumbs a {
    color: #888;
    text-decoration: none;
  }
  .breadcrumbs a:hover {
    color: #2563eb;
  }

  /* === HERO === */
  .article-hero {
    width: 100%;
    aspect-ratio: 21 / 7;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .article-hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 120px;
    background: linear-gradient(transparent, #0d0d0d);
  }
  .hero-emoji {
    font-size: 80px;
    line-height: 1;
    position: relative;
    z-index: 1;
  }

  /* === ARTICLE WRAP === */
  .article-wrap {
    max-width: 1280px;
    margin: -40px auto 0;
    padding: 0 40px 60px;
    position: relative;
    z-index: 2;
  }

  /* === MAIN GRID === */
  .article-main {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 48px;
    align-items: start;
  }
  .article-content {
    min-width: 0;
  }

  /* === CATEGORY LABEL === */
  .article-cat {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #2563eb;
    margin-bottom: 12px;
    display: inline-block;
  }

  /* === TITLE === */
  .article-title {
    font-size: 36px;
    font-weight: 800;
    color: #fff;
    line-height: 1.25;
    margin-bottom: 16px;
  }

  /* === META === */
  .article-meta {
    display: flex;
    align-items: center;
    gap: 20px;
    font-size: 13px;
    color: #666;
    margin-bottom: 32px;
    padding-bottom: 24px;
    border-bottom: 1px solid #1a1a1a;
  }
  .article-meta .author {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .author-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #2563eb;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
  }

  /* === INTRO === */
  .intro-paragraph {
    font-size: 17px;
    color: #ccc;
    line-height: 1.85;
    margin-bottom: 24px;
  }

  /* === ARTICLE BODY === */
  .article-body {
    font-size: 16px;
    line-height: 1.85;
    color: #ccc;
  }
  .article-body :global(h2) {
    font-size: 24px;
    font-weight: 700;
    color: #fff;
    margin: 40px 0 16px;
  }
  .article-body :global(h3) {
    font-size: 19px;
    font-weight: 600;
    color: #fff;
    margin: 32px 0 12px;
  }
  .article-body :global(p) {
    margin-bottom: 20px;
  }
  .article-body :global(strong) {
    color: #fff;
  }
  .article-body :global(ul) {
    margin: 12px 0 20px 20px;
  }
  .article-body :global(li) {
    margin-bottom: 8px;
    color: #bbb;
  }
  .article-body :global(a) {
    color: #2563eb;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }
  .article-body :global(a:hover) {
    border-bottom-color: #2563eb;
  }
  .article-body :global(blockquote) {
    border-left: 3px solid #2563eb;
    padding: 16px 24px;
    margin: 24px 0;
    background: #111;
    border-radius: 0 12px 12px 0;
    font-style: italic;
    color: #aaa;
  }
  .article-body :global(.info-box) {
    background: #0f1a2e;
    border: 1px solid #1a2e4e;
    border-radius: 12px;
    padding: 20px 24px;
    margin: 24px 0;
  }
  .article-body :global(.info-box h4) {
    font-size: 14px;
    font-weight: 700;
    color: #2563eb;
    margin-bottom: 8px;
  }

  /* === CONCLUSION === */
  .conclusion-paragraph {
    font-size: 16px;
    color: #ccc;
    line-height: 1.85;
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid #1a1a1a;
  }

  /* === INTERNAL LINKS === */
  .internal-links-section {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid #1a1a1a;
  }
  .internal-links-section h2 {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 16px;
    color: #fff;
  }
  .internal-links-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .internal-links-list li {
    margin-bottom: 12px;
  }
  .internal-links-list a {
    color: #2563eb;
    text-decoration: none;
    font-size: 15px;
    transition: color 0.2s;
  }
  .internal-links-list a:hover {
    color: #fff;
  }

  /* === TAGS === */
  .article-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid #1a1a1a;
  }
  .tag {
    padding: 6px 14px;
    background: #1a1a2e;
    color: #7aa2f7;
    font-size: 12px;
    border-radius: 20px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
  }
  .tag:hover {
    background: #2a2a4e;
  }

  /* === SHARE === */
  .share-row {
    display: flex;
    gap: 8px;
    margin-top: 24px;
    flex-wrap: wrap;
  }
  .share-btn {
    padding: 8px 16px;
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 8px;
    color: #aaa;
    font-size: 12px;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
  }
  .share-btn:hover {
    border-color: #2563eb;
    color: #fff;
  }

  /* === SIDEBAR === */
  .article-sidebar {
    position: sticky;
    top: 100px;
  }

  .sidebar-section {
    background: #131313;
    border: 1px solid #1e1e1e;
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 20px;
  }
  .sidebar-title {
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 16px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* TOC */
  .toc-nav {
    display: flex;
    flex-direction: column;
  }
  .toc-link {
    display: block;
    padding: 8px 12px;
    color: #888;
    font-size: 13px;
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: all 0.2s;
    margin-bottom: 2px;
  }
  .toc-link:hover,
  .toc-link.active {
    color: #2563eb;
    border-left-color: #2563eb;
    background: #0f1a2e;
    border-radius: 0 8px 8px 0;
  }

  /* Video cards */
  .video-card-sm {
    display: flex;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid #1a1a1a;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s;
  }
  .video-card-sm:last-child {
    border-bottom: none;
  }
  .video-card-sm:hover {
    opacity: 0.8;
  }
  .video-thumb-placeholder {
    width: 96px;
    height: 54px;
    border-radius: 8px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }
  .video-card-info {
    min-width: 0;
  }
  .video-card-title {
    font-size: 13px;
    font-weight: 600;
    color: #ddd;
    line-height: 1.3;
    margin-bottom: 4px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .video-card-price {
    font-size: 12px;
    color: #2563eb;
    font-weight: 700;
  }

  /* CTA */
  .cta-box {
    background: linear-gradient(135deg, #0f1a2e, #1a2e4e);
    border: 1px solid rgba(37, 99, 235, 0.2);
    border-radius: 16px;
    padding: 24px;
    text-align: center;
  }
  .cta-box h3 {
    font-size: 16px;
    font-weight: 700;
    color: #fff;
    margin: 0 0 8px;
  }
  .cta-box p {
    font-size: 13px;
    color: #aaa;
    margin: 0 0 16px;
    line-height: 1.5;
  }
  .cta-btn {
    display: inline-block;
    padding: 12px 28px;
    background: #2563eb;
    color: #fff;
    border-radius: 10px;
    font-weight: 700;
    font-size: 14px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .cta-btn:hover {
    background: #1d4ed8;
  }

  /* === RELATED ARTICLES === */
  .related-articles {
    margin-top: 48px;
    padding-top: 40px;
    border-top: 1px solid #1a1a1a;
  }
  .related-title {
    font-size: 22px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 24px;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .related-card {
    background: #131313;
    border: 1px solid #1e1e1e;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }
  .related-card:hover {
    border-color: #2563eb;
    transform: translateY(-2px);
  }
  .related-card .img-placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
  }
  .related-card-body {
    padding: 14px 16px;
  }
  .related-card-cat {
    font-size: 10px;
    font-weight: 700;
    color: #2563eb;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .related-card-title {
    font-size: 14px;
    font-weight: 600;
    color: #ddd;
    margin-top: 4px;
    line-height: 1.35;
  }

  /* === RESPONSIVE === */
  @media (max-width: 1024px) {
    .article-main {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .article-sidebar {
      position: static;
    }
    .article-wrap {
      padding: 0 24px 40px;
    }
    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .article-hero {
      aspect-ratio: 21 / 10;
    }
    .article-title {
      font-size: clamp(22px, 5vw, 30px);
    }
    .article-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
    .article-wrap {
      padding: 0 16px 32px;
    }
    .breadcrumbs {
      padding: 12px 16px;
      font-size: 12px;
    }
    .related-grid {
      grid-template-columns: 1fr;
    }
    .share-row {
      flex-wrap: wrap;
    }
    .share-btn {
      flex: 1;
      min-width: 120px;
      text-align: center;
    }
  }
</style>
