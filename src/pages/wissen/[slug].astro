---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Topbar from '../../components/Topbar.astro';
import Footer from '../../components/Footer.astro';
import articles from '../../data/articles.json';

export function getStaticPaths() {
  return articles
    .filter(a => a.status !== 'draft')
    .map(article => ({
      params: { slug: article.slug },
      props: { article }
    }));
}

const { article } = Astro.props;
const allArticles = articles.filter(a => a.status !== 'draft' && a.slug !== article.slug);

// Related articles: same category first, then random
const sameCategory = allArticles.filter(a => a.category === article.category);
const others = allArticles.filter(a => a.category !== article.category);
const related = [...sameCategory, ...others].slice(0, 3);

// Build TOC from sections
const toc = (article.sections || []).map((s, i) => ({
  id: 'section-' + i,
  text: s.heading
}));

const catColors: Record<string, string> = {
  'Grundlagen': '#1473e6',
  'Produktion': '#8b5cf6',
  'Marketing': '#ec4899',
  'Recht': '#f59e0b',
  'Technologie': '#06b6d4',
  'Business': '#10b981',
  'Branche': '#6366f1'
};
const catColor = article.categoryColor || catColors[article.category] || '#1473e6';

const dateStr = article.publishDate || article.scheduledDate || new Date().toISOString().split('T')[0];
const formattedDate = new Date(dateStr + 'T00:00:00').toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' });

const schema = {
  \"@context\": \"https://schema.org\",
  \"@type\": \"Article\",
  \"headline\": article.seoTitle || article.title,
  \"description\": article.metaDescription,
  \"datePublished\": dateStr,
  \"dateModified\": dateStr,
  \"author\": { \"@type\": \"Organization\", \"name\": \"stockvideo.de\", \"url\": \"https://stockvideo.de\" },
  \"publisher\": { \"@type\": \"Organization\", \"name\": \"stockvideo.de\", \"logo\": { \"@type\": \"ImageObject\", \"url\": \"https://stockvideo.de/favicon.svg\" } },
  \"mainEntityOfPage\": { \"@type\": \"WebPage\", \"@id\": `https://stockvideo.de/wissen/${article.slug}/` }
};

const faqItems = (article.sections || []).filter(s => s.heading && s.heading.includes('?'));
const faqSchema = faqItems.length > 0 ? {
  \"@context\": \"https://schema.org\",
  \"@type\": \"FAQPage\",
  \"mainEntity\": faqItems.map(s => ({
    \"@type\": \"Question\",
    \"name\": s.heading,
    \"acceptedAnswer\": { \"@type\": \"Answer\", \"text\": (s.paragraphs || []).join(' ').substring(0, 300) }
  }))
} : null;
---

<BaseLayout title={article.seoTitle || article.title} description={article.metaDescription}>
  <Topbar />
  <script type=\"application/ld+json\" set:html={JSON.stringify(schema)} />
  {faqSchema && <script type=\"application/ld+json\" set:html={JSON.stringify(faqSchema)} />}

  <main class=\"article-page\">
    <nav class=\"breadcrumbs\">
      <a href=\"/wissen/\">Wissen</a><span>/</span>
      <a href={`/wissen/?cat=${encodeURIComponent(article.category)}`}>{article.category}</a><span>/</span>
      <span>{article.title}</span>
    </nav>

    <div class=\"article-layout\">
      <article class=\"article-main\">
        <span class=\"article-cat-badge\" style={`background:${catColor}`}>{article.category.toUpperCase()}</span>
        <h1>{article.title}</h1>
        <div class=\"article-meta\">
          <span>📖 {article.readTime} Min. Lesezeit</span><span>·</span>
          <span>Zuletzt aktualisiert: {formattedDate}</span>
        </div>
        <figure class=\"article-hero\">
          <div class=\"article-hero-img\" style={`background: linear-gradient(135deg, ${catColor}44, ${catColor}22); aspect-ratio: 16/9; border-radius: 12px;`}></div>
          {article.imageAlt && <figcaption>{article.imageAlt}</figcaption>}
        </figure>
        <div class=\"article-intro\"><p set:html={article.intro} /></div>

        {(article.sections || []).map((section, i) => (
          <section class=\"article-section\" id={`section-${i}`}>
            <h2>{section.heading}</h2>
            {(section.paragraphs || []).map(para => (
              <p set:html={para} />
            ))}
          </section>
        ))}

        {article.conclusion && (
          <div class=\"article-conclusion\"><p set:html={article.conclusion} /></div>
        )}

        <div class=\"article-cta-box\">
          <h3>Jetzt passende Stock Videos entdecken</h3>
          <p>Finden Sie hochwertige, lizenzfreie 4K-Videoclips für Ihr nächstes Projekt auf stockvideo.de</p>
          <a href=\"/\" class=\"article-cta-btn\">Stock Videos durchsuchen →</a>
        </div>

        {(article.internalLinks || []).length > 0 && (
          <section class=\"article-sources\">
            <h2>Weiterführende Artikel</h2>
            <ul>
              {article.internalLinks.map(link => {
                const url = typeof link === 'string' ? link : link.url;
                const label = typeof link === 'string' ? link : (link.label || link.url);
                return <li><a href={url}>{label}</a></li>;
              })}
            </ul>
          </section>
        )}

        {article.wikipediaUrl && (
          <section class=\"article-sources\">
            <h2>Quellen</h2>
            <ul><li><a href={article.wikipediaUrl} target=\"_blank\" rel=\"noopener\">{article.wikipediaAnchor || 'Wikipedia'}</a></li></ul>
          </section>
        )}

        {related.length > 0 && (
          <section class=\"article-related\">
            <h2>Verwandte Artikel</h2>
            <div class=\"related-grid\">
              {related.map(r => {
                const rColor = r.categoryColor || catColors[r.category] || '#1473e6';
                return (
                  <a href={`/wissen/${r.slug}/`} class=\"related-card\">
                    <div class=\"related-card-img\" style={`background: linear-gradient(135deg, ${rColor}66, ${rColor}22);`}></div>
                    <div class=\"related-card-body\">
                      <span class=\"related-cat\" style={`color:${rColor}`}>{r.category}</span>
                      <h3>{r.title}</h3>
                      <span class=\"related-meta\">{r.readTime} Min. Lesezeit</span>
                    </div>
                  </a>
                );
              })}
            </div>
          </section>
        )}
      </article>

      <aside class=\"article-sidebar\">
        {toc.length > 0 && (
          <div class=\"sidebar-toc\">
            <h4>Inhaltsverzeichnis</h4>
            <nav>
              {toc.map(item => (
                <a href={`#${item.id}`} class=\"toc-link\">{item.text}</a>
              ))}
            </nav>
          </div>
        )}
        <div class=\"sidebar-cta\">
          <h4>Stock Videos kaufen</h4>
          <p>Lizenzfreie 4K-Videos ab 1,19 €</p>
          <a href=\"/\" class=\"sidebar-cta-btn\">Jetzt entdecken</a>
        </div>
      </aside>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .article-page { max-width: 1200px; margin: 0 auto; padding: 30px 24px 60px; }
  .breadcrumbs { display: flex; gap: 8px; font-size: 14px; color: #888; margin-bottom: 24px; flex-wrap: wrap; }
  .breadcrumbs a { color: #1473e6; text-decoration: none; }
  .breadcrumbs a:hover { text-decoration: underline; }
  .article-layout { display: flex; gap: 40px; }
  .article-main { flex: 1; min-width: 0; }
  .article-sidebar { width: 280px; flex-shrink: 0; }
  @media (max-width: 900px) { .article-layout { flex-direction: column; } .article-sidebar { width: 100%; } }
  .article-cat-badge { display: inline-block; padding: 4px 14px; border-radius: 20px; color: #fff; font-size: 12px; font-weight: 700; letter-spacing: 1px; margin-bottom: 12px; }
  h1 { font-size: 2.2rem; line-height: 1.2; margin: 0 0 12px; color: #fff; font-family: 'Source Sans 3', sans-serif; }
  .article-meta { display: flex; gap: 8px; color: #888; font-size: 14px; margin-bottom: 24px; }
  .article-hero { margin: 0 0 32px; }
  .article-hero-img { width: 100%; border-radius: 12px; }
  .article-hero figcaption { font-size: 13px; color: #888; margin-top: 8px; font-style: italic; }
  .article-intro { font-size: 18px; line-height: 1.7; color: #ccc; margin-bottom: 32px; border-left: 3px solid #1473e6; padding-left: 16px; }
  .article-intro p { margin: 0; }
  .article-section { margin-bottom: 32px; }
  .article-section h2 { font-size: 1.5rem; color: #fff; margin: 0 0 16px; padding-top: 8px; font-family: 'Source Sans 3', sans-serif; }
  .article-section p { font-size: 16px; line-height: 1.8; color: #ccc; margin: 0 0 12px; }
  .article-section p :global(a) { color: #1473e6; text-decoration: underline; text-underline-offset: 2px; }
  .article-section p :global(a:hover) { color: #3b9aff; }
  .article-conclusion { font-size: 16px; line-height: 1.8; color: #ccc; margin-bottom: 32px; padding: 20px; background: #222; border-radius: 12px; border: 1px solid #333; }
  .article-conclusion p { margin: 0; }
  .article-cta-box { background: linear-gradient(135deg, #1473e6, #0d5fcf); border-radius: 16px; padding: 32px; text-align: center; margin: 40px 0; }
  .article-cta-box h3 { color: #fff; font-size: 22px; margin: 0 0 8px; }
  .article-cta-box p { color: rgba(255,255,255,0.85); font-size: 15px; margin: 0 0 20px; }
  .article-cta-btn { display: inline-block; background: #fff; color: #1473e6; padding: 12px 32px; border-radius: 10px; font-weight: 700; text-decoration: none; font-size: 16px; transition: transform .2s, box-shadow .2s; }
  .article-cta-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.3); }
  .article-sources { margin-bottom: 32px; }
  .article-sources h2 { font-size: 1.2rem; color: #fff; margin: 0 0 12px; }
  .article-sources ul { list-style: none; padding: 0; margin: 0; }
  .article-sources li { padding: 6px 0; }
  .article-sources a { color: #1473e6; text-decoration: none; font-size: 15px; }
  .article-sources a:hover { text-decoration: underline; }
  .article-related { margin-top: 48px; }
  .article-related h2 { font-size: 1.3rem; color: #fff; margin: 0 0 20px; }
  .related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  @media (max-width: 768px) { .related-grid { grid-template-columns: 1fr; } }
  @media (min-width: 769px) and (max-width: 1024px) { .related-grid { grid-template-columns: repeat(2, 1fr); } }
  .related-card { display: block; background: #222; border-radius: 12px; overflow: hidden; text-decoration: none; border: 1px solid #333; transition: transform .2s, box-shadow .2s, border-color .2s; cursor: pointer; }
  .related-card:hover { transform: translateY(-4px); box-shadow: 0 8px 25px rgba(0,0,0,0.3); border-color: #555; }
  .related-card-img { height: 120px; width: 100%; }
  .related-card-body { padding: 16px; }
  .related-cat { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
  .related-card h3 { font-size: 15px; color: #fff; margin: 8px 0; line-height: 1.3; font-family: 'Source Sans 3', sans-serif; }
  .related-meta { font-size: 12px; color: #888; }
  .article-sidebar { position: sticky; top: 80px; align-self: flex-start; }
  .sidebar-toc { background: #222; border-radius: 12px; padding: 20px; border: 1px solid #333; margin-bottom: 16px; }
  .sidebar-toc h4 { font-size: 14px; color: #fff; margin: 0 0 12px; text-transform: uppercase; letter-spacing: 0.5px; }
  .toc-link { display: block; padding: 6px 0; font-size: 13px; color: #aaa; text-decoration: none; border-left: 2px solid transparent; padding-left: 12px; transition: all .2s; }
  .toc-link:hover { color: #1473e6; border-left-color: #1473e6; }
  .sidebar-cta { background: #222; border-radius: 12px; padding: 20px; border: 1px solid #333; text-align: center; }
  .sidebar-cta h4 { font-size: 16px; color: #fff; margin: 0 0 8px; }
  .sidebar-cta p { font-size: 13px; color: #888; margin: 0 0 12px; }
  .sidebar-cta-btn { display: inline-block; background: #1473e6; color: #fff; padding: 10px 24px; border-radius: 8px; text-decoration: none; font-size: 14px; font-weight: 600; transition: background .2s; }
  .sidebar-cta-btn:hover { background: #0d5fcf; }
</style>
