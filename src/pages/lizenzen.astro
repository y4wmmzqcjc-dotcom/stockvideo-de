---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Lizenzübersicht — stockvideo.de"
  description="Detaillierte Übersicht aller Lizenzarten für Stock-Videos bei stockvideo.de. Web, Broadcast und Extended Lizenz im Vergleich."
>
  <Navbar />
  <main class="section">
    <div class="container" style="max-width: 860px;">
      <h1>Lizenzübersicht</h1>
      <p style="margin-top: 12px; font-size: 1.0625rem;">
        Alle Lizenzen gewähren Ihnen ein nicht-exklusives, weltweites, dauerhaftes Recht zur Nutzung des Videos
        gemäß den unten aufgeführten Bedingungen.
      </p>

      <div class="license-table-wrap" style="margin-top: 48px; overflow-x: auto;">
        <table class="license-table" role="table" aria-label="Lizenzvergleich">
          <thead>
            <tr>
              <th scope="col">Verwendungszweck</th>
              <th scope="col">Web</th>
              <th scope="col">Broadcast</th>
              <th scope="col">Extended</th>
            </tr>
          </thead>
          <tbody>
            {[
              ['Website & Blog', '✅', '✅', '✅'],
              ['Social Media (organisch)', '✅', '✅', '✅'],
              ['YouTube & Streaming', '✅ bis 1 Mio.', '✅ unbegrenzt', '✅ unbegrenzt'],
              ['Online-Werbung', '✅', '✅', '✅'],
              ['TV & Kinowerbung', '❌', '✅', '✅'],
              ['Printmedien', '❌', '❌', '✅'],
              ['Produktverpackungen', '❌', '❌', '✅'],
              ['Template & Weiterverkauf', '❌', '❌', '✅'],
              ['OEM & Einbettung in Software', '❌', '❌', '✅'],
              ['Interne Unternehmensnutzung', '✅', '✅', '✅'],
              ['Bildungseinrichtungen', '✅', '✅', '✅'],
              ['Gemeinnützige Organisationen', '✅', '✅', '✅'],
            ].map(row => (
              <tr>
                {row.map((cell, i) => (
                  i === 0
                    ? <th scope="row">{cell}</th>
                    : <td>{cell}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div style="margin-top: 48px;">
        <h2>Allgemeine Lizenzbedingungen</h2>
        <div style="margin-top: 20px; display: flex; flex-direction: column; gap: 16px;">
          {[
            {
              title: 'Einmalzahlung',
              text: 'Sie zahlen einmalig den Lizenzpreis und dürfen das Video dauerhaft in der lizenzierten Form verwenden.',
            },
            {
              title: 'Nicht übertragbar',
              text: 'Die Lizenz gilt für den lizenzierten Rechtsnehmer und darf nicht an Dritte weitergegeben werden, es sei denn, die Extended-Lizenz erlaubt es ausdrücklich.',
            },
            {
              title: 'Keine Bearbeitung des Urhebernachweises',
              text: 'Sie dürfen das Video zuschneiden, farblich anpassen und in eigene Werke integrieren, dürfen jedoch nicht vorgeben, das Video selbst aufgenommen zu haben.',
            },
            {
              title: 'Modellfreigaben',
              text: 'Alle im Material abgebildeten Personen haben eine Modellfreigabe unterzeichnet. Dennoch sind diskriminierende oder rufschädigende Verwendungen untersagt.',
            },
          ].map(item => (
            <div style="background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 20px 24px;">
              <h3 style="font-size: 1rem; margin-bottom: 6px;">{item.title}</h3>
              <p style="font-size: 0.875rem;">{item.text}</p>
            </div>
          ))}
        </div>
      </div>

      <p style="margin-top: 40px; text-align: center; color: var(--color-text-muted); font-size: 0.875rem;">
        Fragen zur Lizenzierung? <a href="/kontakt" style="color: var(--color-accent);">Kontakt aufnehmen →</a>
      </p>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
.license-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.9rem;
}
.license-table th, .license-table td {
  padding: 12px 16px;
  text-align: center;
  border: 1px solid var(--color-border);
}
.license-table th[scope="row"] { text-align: left; font-weight: 400; color: var(--color-text-muted); }
.license-table thead th {
  background: var(--color-bg-3);
  font-weight: 700;
  color: var(--color-text);
}
.license-table tbody tr:hover { background: var(--color-bg-3); }
</style>
