---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Lizenzbedingungen · stockvideo.de"
  description="Einmal kaufen, unbegrenzt nutzen. Die Royalty-Free-Lizenz von stockvideo.de in verständlich - ohne Kleingedrucktes, ohne Abofallen, nach deutschem Recht."
>
  <Topbar />

  <!-- ═══════════════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════════════ -->
  <section class="hero-section">
    <div class="hero-bg">
      <img
        src="/images/making-of/making-of-051.jpg"
        alt="Filmset mit Kamera und professionellem Equipment"
        class="hero-img"
      />
      <div class="hero-overlay"></div>
      <div class="hero-grain"></div>
    </div>

    <div class="grid-lines" aria-hidden="true">
      <div class="gl gl1"></div>
      <div class="gl gl2"></div>
      <div class="gl gl3"></div>
      <div class="gl gl4"></div>
    </div>

    <div class="hero-content">
      <div class="hero-eyebrow">
        <span class="dot-pulse"></span>
        <span>Royalty Free · Nach deutschem Recht</span>
      </div>
      <h1 class="hero-headline">
        <span class="line-reveal">Einmal kaufen.</span>
        <span class="line-reveal delay1">Unbegrenzt nutzen.</span>
        <span class="line-reveal delay2 accent-line">So einfach ist Lizenzrecht.</span>
      </h1>
      <p class="hero-sub">
        Keine Abogebühren, keine Staffelpreise, keine versteckten Klauseln.
        Jeder Clip kommt mit einer klaren Royalty-Free-Lizenz - weltweit,
        zeitlich unbegrenzt und kommerziell nutzbar.
      </p>
      <div class="hero-stats">
        <div class="stat-item">
          <span class="stat-num" data-target="100">0</span><span class="stat-unit">%</span>
          <span class="stat-label">Rechtssicher</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-item">
          <span class="stat-num" data-target="0">0</span><span class="stat-unit">€</span>
          <span class="stat-label">Folgekosten</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-item">
          <span class="stat-prefix">∞</span>
          <span class="stat-label">Nutzungsdauer</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-item">
          <span class="stat-prefix">DE</span>
          <span class="stat-label">Recht &amp; Rechnung</span>
        </div>
      </div>
    </div>

    <div class="scroll-hint" aria-hidden="true">
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       LIZENZ-KERN
  ═══════════════════════════════════════════════════════════════ -->
  <section class="pillars-section reveal-section">
    <div class="pillars-head">
      <div class="pillar-label">
        <span class="pillar-icon">
          <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="8" y="6" width="24" height="28" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M14 14H26M14 20H26M14 26H22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </span>
        <span class="pillar-tag">01 · Das Wichtigste auf einen Blick</span>
      </div>
      <h2 class="pillar-title">Was deine Lizenz abdeckt.</h2>
      <p class="pillar-text">
        Royalty Free bedeutet: Du zahlst einmalig und bekommst dafür ein sehr
        weitreichendes Nutzungsrecht. Hier die vier Eckpfeiler, die für jeden
        Clip gelten.
      </p>
    </div>

    <div class="pillars-grid">
      <div class="m-pillar">
        <div class="m-icon">
          <svg viewBox="0 0 32 32" fill="none">
            <circle cx="16" cy="16" r="11" stroke="currentColor" stroke-width="1.5"/>
            <path d="M11 16L14.5 19.5L21 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <strong>Einmalzahlung</strong>
        <span>Kein Abo, keine Folgekosten. Nach dem Kauf gehört das Nutzungsrecht dir.</span>
      </div>
      <div class="m-pillar">
        <div class="m-icon">
          <svg viewBox="0 0 32 32" fill="none">
            <circle cx="16" cy="16" r="11" stroke="currentColor" stroke-width="1.5"/>
            <path d="M6 16H26M16 6C19 10 19 22 16 26C13 22 13 10 16 6Z" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <strong>Weltweit</strong>
        <span>Deutschland, DACH, global - keine geografischen Einschränkungen.</span>
      </div>
      <div class="m-pillar">
        <div class="m-icon">
          <svg viewBox="0 0 32 32" fill="none">
            <path d="M16 4V16L24 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="16" cy="16" r="12" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <strong>Zeitlich unbegrenzt</strong>
        <span>Deine Projekte dürfen laufen, solange du möchtest. Auch in zehn Jahren.</span>
      </div>
      <div class="m-pillar">
        <div class="m-icon">
          <svg viewBox="0 0 32 32" fill="none">
            <rect x="5" y="8" width="22" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M10 14H22M10 18H18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <strong>Kommerziell nutzbar</strong>
        <span>Werbung, Branding, Kundenprojekte, Social Ads - alles inklusive.</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       ERLAUBT VS. NICHT ERLAUBT
  ═══════════════════════════════════════════════════════════════ -->
  <section class="rules-section reveal-section">
    <div class="rules-inner">
      <div class="rules-head">
        <div class="pillar-label">
          <span class="pillar-icon">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 4L24 12H32L26 18L28 28L20 24L12 28L14 18L8 12H16L20 4Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="pillar-tag">02 · Die Regeln</span>
        </div>
        <h2 class="pillar-title">Was geht.<br/>Und was nicht.</h2>
        <p class="pillar-text">
          Die Lizenz ist bewusst großzügig - aber nicht grenzenlos.
          Diese Gegenüberstellung klärt die häufigsten Fragen.
        </p>
      </div>

      <div class="rules-grid">
        <div class="rules-card rules-card--allow">
          <div class="rules-card-head">
            <div class="rules-badge rules-badge--allow">
              <svg viewBox="0 0 20 20" fill="none"><path d="M4 10L8.5 14.5L16 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3>Erlaubt</h3>
          </div>
          <ul class="rules-list">
            <li>
              <span class="rules-bullet rules-bullet--allow"></span>
              <span><strong>Kommerzielle und nicht-kommerzielle Nutzung</strong> - Werbung, Branding, Lehre, privat.</span>
            </li>
            <li>
              <span class="rules-bullet rules-bullet--allow"></span>
              <span><strong>Bearbeitung und Einbindung</strong> in eigene Projekte - Schnitt, Farbkorrektur, Komposition, KI-Nachbearbeitung.</span>
            </li>
            <li>
              <span class="rules-bullet rules-bullet--allow"></span>
              <span><strong>Kundenprojekte</strong> - eine Lizenz pro Endprodukt. Du darfst im Auftrag produzieren.</span>
            </li>
            <li>
              <span class="rules-bullet rules-bullet--allow"></span>
              <span><strong>Weltweite Nutzung</strong>, zeitlich unbegrenzt - auf allen Kanälen, in jeder Sprache.</span>
            </li>
            <li>
              <span class="rules-bullet rules-bullet--allow"></span>
              <span><strong>Alle Medien</strong> - TV, Kino, Web, Social Media, Streaming, OOH, Eventprojektion.</span>
            </li>
          </ul>
        </div>

        <div class="rules-card rules-card--deny">
          <div class="rules-card-head">
            <div class="rules-badge rules-badge--deny">
              <svg viewBox="0 0 20 20" fill="none"><path d="M6 6L14 14M14 6L6 14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </div>
            <h3>Nicht erlaubt</h3>
          </div>
          <ul class="rules-list">
            <li>
              <span class="rules-bullet rules-bullet--deny"></span>
              <span><strong>Weiterverkauf oder Sublizenzierung</strong> des Rohmaterials - Clips bleiben nicht als Datei handelbar.</span>
            </li>
            <li>
              <span class="rules-bullet rules-bullet--deny"></span>
              <span><strong>Diffamierende oder rechtswidrige Kontexte</strong> - Inhalte, die Personen oder Marken verletzen.</span>
            </li>
            <li>
              <span class="rules-bullet rules-bullet--deny"></span>
              <span><strong>Urheberschaft behaupten</strong> am Originalmaterial - der Clip bleibt Werk der Rechteinhaber.</span>
            </li>
            <li>
              <span class="rules-bullet rules-bullet--deny"></span>
              <span><strong>Bestandteil einer konkurrierenden Stockplattform</strong> - keine Integration in andere Clip-Bibliotheken.</span>
            </li>
            <li>
              <span class="rules-bullet rules-bullet--deny"></span>
              <span><strong>NFTs oder Blockchain-Assets</strong> - keine Tokenisierung des Rohmaterials.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       FAQ-STRIP
  ═══════════════════════════════════════════════════════════════ -->
  <section class="faq-section reveal-section">
    <div class="faq-inner">
      <div class="pillar-label">
        <span class="pillar-icon">
          <svg viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="20" r="14" stroke="currentColor" stroke-width="1.5"/>
            <path d="M16 16C16 13.8 17.8 12 20 12C22.2 12 24 13.8 24 16C24 18 22 18.5 20 20V22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="20" cy="27" r="1" fill="currentColor"/>
          </svg>
        </span>
        <span class="pillar-tag">03 · Die häufigsten Fragen</span>
      </div>
      <h2 class="pillar-title">Klare Antworten.<br/>Keine Fußnoten.</h2>

      <div class="faq-list">
        <details class="faq-item">
          <summary>
            <span>Brauche ich für jedes Projekt eine neue Lizenz?</span>
            <span class="faq-chevron" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="none"><path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </summary>
          <div class="faq-body">
            <p>
              Nein. Ein einzelner Clip ist nach dem Kauf für beliebig viele eigene
              Projekte nutzbar. Nur bei Kundenprojekten gilt: eine Lizenz pro
              Endprodukt - also pro Film, Kampagne oder Spot, nicht pro
              Ausspielungskanal.
            </p>
          </div>
        </details>

        <details class="faq-item">
          <summary>
            <span>Darf ich die Clips in TV-Werbung oder Kinospots nutzen?</span>
            <span class="faq-chevron" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="none"><path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </summary>
          <div class="faq-body">
            <p>
              Ja. Alle Standardlizenzen decken TV, Kino, Streaming, Social Media,
              Event-LED-Walls und OOH ab. Staffelpreise nach Reichweite gibt es
              bei uns nicht.
            </p>
          </div>
        </details>

        <details class="faq-item">
          <summary>
            <span>Muss ich stockvideo.de im Abspann oder Impressum nennen?</span>
            <span class="faq-chevron" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="none"><path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </summary>
          <div class="faq-body">
            <p>
              Nicht zwingend. Eine Nennung ist nicht erforderlich - freut uns
              aber natürlich. Eine Behauptung der eigenen Urheberschaft am
              Rohmaterial ist ausgeschlossen.
            </p>
          </div>
        </details>

        <details class="faq-item">
          <summary>
            <span>Kann ich die Clips mit KI weiterbearbeiten?</span>
            <span class="faq-chevron" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="none"><path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </summary>
          <div class="faq-body">
            <p>
              Ja. Upscaling, Retusche, Stilübertragung und Schnittautomatisierung
              sind erlaubt, solange das Ergebnis Bestandteil deines Projekts wird.
              Untersagt bleibt das Einspeisen in öffentlich zugängliche KI-Trainingssets
              und die Wiederveröffentlichung als generisches Stock-Asset.
            </p>
          </div>
        </details>

        <details class="faq-item">
          <summary>
            <span>Was passiert, wenn sich die Lizenzbedingungen ändern?</span>
            <span class="faq-chevron" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="none"><path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </summary>
          <div class="faq-body">
            <p>
              Die zum Kaufzeitpunkt gültigen Bedingungen gelten weiter. Spätere
              Änderungen betreffen nur neue Käufe. Deine bestehenden Lizenzen
              bleiben unverändert bestehen.
            </p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       FINAL CTA
  ═══════════════════════════════════════════════════════════════ -->
  <section class="final-cta reveal-section">
    <div class="fta-inner">
      <div class="fta-glow" aria-hidden="true"></div>
      <div class="fta-tag">Noch unsicher?</div>
      <h2 class="fta-headline">Dann klären wir<br/>das persönlich.</h2>
      <p class="fta-sub">
        Für Enterprise-Anfragen, Sonderfälle oder ungewöhnliche Einsatzszenarien
        schreib uns einfach eine Mail. Wir finden eine Antwort - ohne juristische Nebelkerze.
      </p>
      <div class="fta-actions">
        <a href="/kontakt" class="btn-cta-primary">Kontakt aufnehmen</a>
        <a href="/agb" class="btn-cta-secondary">Komplette AGB lesen</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<!-- ═══════════════════════════════════════════════════════════════
     STYLES
═══════════════════════════════════════════════════════════════ -->
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  /* ─── HERO ─── */
  .hero-section {
    position: relative;
    min-height: 88vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: #000;
  }
  .hero-bg { position: absolute; inset: 0; }
  .hero-img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 40%;
    opacity: 0.55;
    transform: scale(1.04);
    animation: slowZoom 20s ease-out forwards;
  }
  @keyframes slowZoom {
    from { transform: scale(1.08); }
    to   { transform: scale(1.00); }
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.3) 0%,
      rgba(0,0,0,0.1) 30%,
      rgba(0,0,0,0.6) 70%,
      rgba(0,0,0,0.92) 100%
    );
  }
  .hero-grain {
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    opacity: 0.4;
    pointer-events: none;
  }

  .grid-lines { position: absolute; inset: 0; pointer-events: none; }
  .gl {
    position: absolute; top: 0; bottom: 0; width: 1px;
    background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.06) 20%, rgba(255,255,255,0.06) 80%, transparent);
  }
  .gl1 { left: 25%; } .gl2 { left: 50%; } .gl3 { left: 75%; }
  .gl4 { left: 0; right: 0; top: auto; bottom: 0; height: 1px; width: 100%; background: linear-gradient(to right, transparent, rgba(255,255,255,0.08), transparent); }

  .hero-content {
    position: relative; z-index: 2;
    padding: clamp(80px, 10vw, 140px) clamp(24px, 6vw, 100px) clamp(60px, 8vw, 100px);
    max-width: 900px;
  }
  .hero-eyebrow {
    display: flex; align-items: center; gap: 12px;
    color: rgba(255,255,255,0.55);
    font-size: 12px; letter-spacing: 0.15em; text-transform: uppercase;
    margin-bottom: 32px;
    animation: fadeUp 0.8s 0.2s both;
  }
  .dot-pulse {
    display: inline-block; width: 8px; height: 8px; border-radius: 50%;
    background: #e8c97a;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.7); }
  }

  .hero-headline {
    display: flex; flex-direction: column;
    font-size: clamp(38px, 6.2vw, 80px);
    font-weight: 800; line-height: 1.05;
    color: #fff; letter-spacing: -0.02em;
    margin-bottom: 28px;
  }
  .line-reveal {
    display: block;
    opacity: 0; transform: translateY(24px);
    animation: fadeUp 0.7s ease-out forwards;
  }
  .delay1 { animation-delay: 0.3s; }
  .delay2 { animation-delay: 0.55s; }
  .accent-line { color: #e8c97a; }
  @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }

  .hero-sub {
    font-size: clamp(15px, 1.4vw, 18px); color: rgba(255,255,255,0.65);
    line-height: 1.7; max-width: 620px;
    margin-bottom: 48px;
    animation: fadeUp 0.8s 0.7s both;
  }

  .hero-stats {
    display: flex; align-items: center; gap: 0;
    flex-wrap: wrap;
    animation: fadeUp 0.8s 0.9s both;
  }
  .stat-item {
    display: flex; flex-direction: column;
    padding: 0 28px 0 0;
  }
  .stat-item:first-child { padding-left: 0; }
  .stat-prefix {
    font-size: clamp(28px, 4vw, 44px); font-weight: 800;
    color: #e8c97a; line-height: 1;
  }
  .stat-num {
    font-size: clamp(28px, 4vw, 44px); font-weight: 800;
    color: #e8c97a; line-height: 1;
    display: inline;
  }
  .stat-unit {
    font-size: clamp(18px, 2.5vw, 28px); font-weight: 700;
    color: #e8c97a;
  }
  .stat-label {
    font-size: 11px; color: rgba(255,255,255,0.45);
    text-transform: uppercase; letter-spacing: 0.1em;
    margin-top: 6px;
  }
  .stat-divider {
    width: 1px; height: 40px; background: rgba(255,255,255,0.15);
    margin: 6px 28px 20px 0;
    align-self: flex-start;
  }

  .scroll-hint { position: absolute; bottom: 40px; right: 60px; z-index: 2; }
  .scroll-line {
    width: 1px; height: 60px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.5), transparent);
    animation: scrollDrop 2s infinite;
  }
  @keyframes scrollDrop {
    0% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
    51% { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  /* ─── SHARED LABEL/TITLE ─── */
  .pillar-label {
    display: flex; align-items: center; gap: 10px;
    color: #e8c97a;
  }
  .pillar-icon { width: 28px; height: 28px; flex-shrink: 0; }
  .pillar-icon svg { width: 100%; height: 100%; }
  .pillar-tag {
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.18em;
    color: rgba(232,201,122,0.8);
  }
  .pillar-title {
    font-size: clamp(26px, 3.5vw, 44px); font-weight: 800;
    color: #fff; line-height: 1.15; letter-spacing: -0.02em;
  }
  .pillar-text { color: rgba(255,255,255,0.6); font-size: 15px; line-height: 1.75; max-width: 640px; }
  .pillar-text p + p { margin-top: 14px; }

  /* ─── LIZENZ-KERN ─── */
  .pillars-section {
    background: #0a0a0b;
    padding: clamp(70px, 9vw, 120px) clamp(24px, 6vw, 100px);
  }
  .pillars-head {
    max-width: 800px;
    margin: 0 auto 56px;
    display: flex; flex-direction: column; gap: 18px;
  }
  .pillars-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    max-width: 1200px; margin: 0 auto;
  }
  .m-pillar {
    display: flex; flex-direction: column; gap: 10px;
    padding: 28px 24px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 10px;
    transition: border-color 0.3s, background 0.3s, transform 0.3s;
  }
  .m-pillar:hover {
    border-color: rgba(232,201,122,0.4);
    background: rgba(232,201,122,0.05);
    transform: translateY(-3px);
  }
  .m-icon { width: 32px; height: 32px; color: #e8c97a; margin-bottom: 4px; }
  .m-icon svg { width: 100%; height: 100%; }
  .m-pillar strong { font-size: 15px; color: #fff; font-weight: 700; }
  .m-pillar span { font-size: 13px; color: rgba(255,255,255,0.55); line-height: 1.6; }

  /* ─── ERLAUBT VS. NICHT ERLAUBT ─── */
  .rules-section {
    background: #050506;
