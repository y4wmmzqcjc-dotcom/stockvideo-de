---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';
import config from '../data/config.json';
---
<BaseLayout title="Kontakt" description="Kontaktieren Sie stockvideo.de">
  <Topbar />
  <div class="page-content">
    <h1>Kontakt</h1>
    <p>Haben Sie Fragen zu unseren Videos, Lizenzen oder benötigen individuelle Beratung? Wir helfen Ihnen gerne weiter.</p>
    <h2>Kontaktdaten</h2>
    <p>
      {config.contact.name}<br>
      {config.contact.street}<br>
      {config.contact.city}<br><br>
      Telefon: {config.contact.phone}<br>
      Fax: {config.contact.fax}<br>
      Email: <a href={`mailto:${config.contact.email}`}>{config.contact.email}</a>
    </p>
    <h2>Kontaktformular</h2>
    <form id="contactForm" style="display:flex;flex-direction:column;gap:16px;max-width:500px;">
      <input type="text" name="name" placeholder="Ihr Name" required style="background:#2c2c2c;border:1px solid #3a3a3a;border-radius:8px;padding:12px 16px;color:#fff;font-size:15px;font-family:inherit;outline:none;">
      <input type="email" name="email" placeholder="Ihre Email-Adresse" required style="background:#2c2c2c;border:1px solid #3a3a3a;border-radius:8px;padding:12px 16px;color:#fff;font-size:15px;font-family:inherit;outline:none;">
      <select name="subject" style="background:#2c2c2c;border:1px solid #3a3a3a;border-radius:8px;padding:12px 16px;color:#ccc;font-size:15px;font-family:inherit;outline:none;">
        <option value="allgemein">Allgemeine Anfrage</option>
        <option value="lizenz">Lizenzfrage</option>
        <option value="technik">Technischer Support</option>
        <option value="enterprise">Enterprise / Agentur</option>
      </select>
      <textarea name="message" placeholder="Ihre Nachricht" rows="6" required style="background:#2c2c2c;border:1px solid #3a3a3a;border-radius:8px;padding:12px 16px;color:#fff;font-size:15px;font-family:inherit;outline:none;resize:vertical;"></textarea>
      <input type="text" name="website" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;opacity:0;pointer-events:none;" aria-hidden="true">
      <div id="contactStatus" style="display:none;padding:12px 14px;border-radius:8px;font-size:14px;"></div>
      <button type="submit" id="contactSubmit" class="btn-primary" style="align-self:flex-start;padding:12px 28px;font-size:15px;">Nachricht senden</button>
    </form>
    <script is:inline>
      (function() {
        const form = document.getElementById('contactForm');
        const status = document.getElementById('contactStatus');
        const btn = document.getElementById('contactSubmit');
        if (!form) return;
        form.addEventListener('submit', async function(e) {
          e.preventDefault();
          status.style.display = 'none';
          btn.disabled = true;
          btn.textContent = 'Wird gesendet …';
          const fd = new FormData(form);
          const payload = {};
          for (const [k, v] of fd.entries()) payload[k] = v;
          try {
            const r = await fetch('/kontakt', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            });
            const data = await r.json().catch(() => ({}));
            if (!r.ok) throw new Error(data.error || 'Versand fehlgeschlagen');
            status.textContent = 'Vielen Dank! Deine Nachricht wurde gesendet. Wir melden uns zeitnah.';
            status.style.background = 'rgba(34,197,94,0.12)';
            status.style.border = '1px solid rgba(34,197,94,0.35)';
            status.style.color = '#86efac';
            status.style.display = 'block';
            form.reset();
          } catch(err) {
            status.textContent = 'Fehler: ' + err.message;
            status.style.background = 'rgba(220,38,38,0.12)';
            status.style.border = '1px solid rgba(220,38,38,0.35)';
            status.style.color = '#fca5a5';
            status.style.display = 'block';
          } finally {
            btn.disabled = false;
            btn.textContent = 'Nachricht senden';
          }
        });
      })();
    </script>
  </div>
  <Footer />
</BaseLayout>
