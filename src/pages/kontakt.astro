---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import config from '../data/config.json';
---

<BaseLayout
  title="Kontakt"
  description="Kontaktieren Sie uns bei Fragen zu unseren Stock Videos"
>
  <Navbar />

  <div class="kontakt-container">
    <div class="container">
      <div class="kontakt-header">
        <h1>Kontakt</h1>
        <p>Haben Sie Fragen? Kontaktieren Sie uns und wir helfen Ihnen gerne weiter.</p>
      </div>

      <div class="kontakt-grid">
        <!-- Contact Form -->
        <div class="kontakt-form-section">
          <h2>Schreiben Sie uns</h2>
          <form id="contactForm" class="kontakt-form">
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required />
            </div>

            <div class="form-group">
              <label for="email">E-Mail</label>
              <input type="email" id="email" name="email" required />
            </div>

            <div class="form-group">
              <label for="subject">Betreff</label>
              <input type="text" id="subject" name="subject" required />
            </div>

            <div class="form-group">
              <label for="message">Nachricht</label>
              <textarea id="message" name="message" rows="5" required></textarea>
            </div>

            <button type="submit" class="btn-submit">Nachricht Absenden</button>
          </form>
          <div id="formMessage" class="form-message"></div>
        </div>

        <!-- Contact Info -->
        <div class="kontakt-info-section">
          <h2>Kontaktinformationen</h2>

          <div class="info-block">
            <h3>Adresse</h3>
            <p>
              Timo Rende<br>
              Haldenstrasse 16<br>
              66806 Saarlouis / Ensdorf<br>
              Deutschland
            </p>
          </div>

          <div class="info-block">
            <h3>Telefon</h3>
            <p>
              <a href="tel:+4968315052856">06831 5052856</a>
            </p>
          </div>

          <div class="info-block">
            <h3>Fax</h3>
            <p>06831 5051619</p>
          </div>

          <div class="info-block">
            <h3>E-Mail</h3>
            <p>
              <a href="mailto:info@stockvideo.de">info@stockvideo.de</a>
            </p>
          </div>

          <div class="info-block">
            <h3>Geschäftszeiten</h3>
            <p>
              Montag - Freitag: 09:00 - 17:00 Uhr<br>
              Samstag & Sonntag: Geschlossen
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <Footer />
</BaseLayout>

<script define:vars={{publicKey: 'YOUR_EMAILJS_PUBLIC_KEY'}}>
  const form = document.getElementById('contactForm');
  const formMessage = document.getElementById('formMessage');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const data = {
      to_email: 'info@stockvideo.de',
      from_name: formData.get('name'),
      from_email: formData.get('email'),
      subject: formData.get('subject'),
      message: formData.get('message'),
    };

    try {
      // Initialize EmailJS
      if (typeof emailjs !== 'undefined') {
        emailjs.init(publicKey);

        const response = await emailjs.send('service_id', 'template_id', data);

        if (response.status === 200) {
          formMessage.innerHTML = '<p class="success">Vielen Dank! Ihre Nachricht wurde erfolgreich versendet.</p>';
          form.reset();
          setTimeout(() => {
            formMessage.innerHTML = '';
          }, 5000);
        }
      } else {
        // Fallback: Send via fetch
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          formMessage.innerHTML = '<p class="success">Vielen Dank! Ihre Nachricht wurde erfolgreich versendet.</p>';
          form.reset();
          setTimeout(() => {
            formMessage.innerHTML = '';
          }, 5000);
        } else {
          formMessage.innerHTML = '<p class="error">Ein Fehler ist aufgetreten. Bitte versuchen Sie es später erneut.</p>';
        }
      }
    } catch (error) {
      console.error('Error:', error);
      formMessage.innerHTML = '<p class="error">Ein Fehler ist aufgetreten. Bitte versuchen Sie es später erneut.</p>';
    }
  });
</script>

<style>
  .kontakt-container {
    background: linear-gradient(135deg, #0a0e27 0%, #1a1f3a 100%);
    padding: 4rem 0;
    min-height: calc(100vh - 200px);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .kontakt-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .kontakt-header h1 {
    font-size: 2.5rem;
    color: #1473e6;
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .kontakt-header p {
    font-size: 1.1rem;
    color: #9ca3af;
  }

  .kontakt-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .kontakt-form-section,
  .kontakt-info-section {
    background: rgba(30, 41, 59, 0.6);
    padding: 2rem;
    border-radius: 12px;
    border: 1px solid rgba(20, 115, 230, 0.1);
  }

  .kontakt-form-section h2,
  .kontakt-info-section h2 {
    font-size: 1.5rem;
    color: #1473e6;
    margin-bottom: 1.5rem;
    font-weight: 600;
  }

  .kontakt-form {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  .form-group label {
    color: #e5e7eb;
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .form-group input,
  .form-group textarea {
    padding: 0.75rem;
    background: rgba(15, 23, 42, 0.8);
    border: 1px solid rgba(20, 115, 230, 0.2);
    border-radius: 6px;
    color: #e5e7eb;
    font-family: inherit;
    font-size: 1rem;
    transition: all 0.2s;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: #1473e6;
    background: rgba(15, 23, 42, 1);
    box-shadow: 0 0 0 3px rgba(20, 115, 230, 0.1);
  }

  .btn-submit {
    padding: 0.75rem 1.5rem;
    background: #1473e6;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    font-size: 1rem;
  }

  .btn-submit:hover {
    background: #0d59cc;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(20, 115, 230, 0.3);
  }

  .btn-submit:active {
    transform: translateY(0);
  }

  .form-message {
    margin-top: 1rem;
  }

  .form-message p {
    padding: 1rem;
    border-radius: 6px;
    font-size: 0.95rem;
    margin: 0;
  }

  .form-message .success {
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    color: #86efac;
  }

  .form-message .error {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #fca5a5;
  }

  .info-block {
    margin-bottom: 2rem;
  }

  .info-block h3 {
    color: #1473e6;
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  .info-block p {
    color: #d1d5db;
    line-height: 1.6;
    margin: 0;
  }

  .info-block a {
    color: #1473e6;
    text-decoration: none;
    transition: color 0.2s;
  }

  .info-block a:hover {
    color: #0d59cc;
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .kontakt-container {
      padding: 2rem 0;
    }

    .kontakt-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .kontakt-header h1 {
      font-size: 1.8rem;
    }

    .kontakt-form-section,
    .kontakt-info-section {
      padding: 1.5rem;
    }
  }
</style>
