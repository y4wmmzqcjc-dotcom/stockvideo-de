---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import PricingSection from '../components/PricingSection.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Preise & Lizenzen — stockvideo.de"
  description="Transparente Preise für Stock-Video-Lizenzen. Web, Broadcast und Extended Lizenz. Einmalzahlung, keine Abos."
>
  <Navbar />
  <main>
    <PricingSection />

    <!-- FAQ -->
    <section class="section">
      <div class="container" style="max-width: 720px;">
        <div class="section-header">
          <h2>Häufige Fragen zu Lizenzen</h2>
        </div>

        <div class="faq-list">
          {[
            {
              q: 'Was darf ich mit der Web-Lizenz machen?',
              a: 'Mit der Web-Lizenz dürfen Sie das Video auf Ihrer Website, in Social-Media-Beiträgen, YouTube-Videos und Online-Anzeigen nutzen — bis zu 1 Million Views pro Plattform.',
            },
            {
              q: 'Gibt es eine zeitliche Begrenzung der Lizenz?',
              a: 'Nein. Sie zahlen einmalig und können das Video dauerhaft in der lizenzierten Form verwenden. Keine Abonnements, keine jährlichen Gebühren.',
            },
            {
              q: 'Kann ich das Video in Kundenprojekten verwenden?',
              a: 'Mit der Web-Lizenz können Sie Videos für eigene Projekte nutzen. Für Agenturen, die Videos für Kunden lizenzieren, empfehlen wir die Broadcast- oder Extended-Lizenz.',
            },
            {
              q: 'Was passiert wenn Cloudflare oder Stripe Gebühren erhebt?',
              a: 'Alle angezeigten Preise sind Nettopreise zzgl. der gesetzlichen Mehrwertsteuer. Zahlungsabwicklungsgebühren sind bereits im Preis enthalten.',
            },
            {
              q: 'Kann ich ein Video exklusiv lizenzieren?',
              a: 'Ja, auf Anfrage bieten wir Exklusivlizenzen an. Kontaktieren Sie uns für ein individuelles Angebot.',
            },
          ].map(item => (
            <details class="faq-item">
              <summary class="faq-question">{item.q}</summary>
              <p class="faq-answer">{item.a}</p>
            </details>
          ))}
        </div>

        <p style="text-align: center; margin-top: 48px; color: var(--color-text-muted); font-size: 0.9rem;">
          Noch Fragen? <a href="/kontakt" style="color: var(--color-accent);">Schreib uns</a> — wir antworten innerhalb von 24 Stunden.
        </p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
.faq-list { display: flex; flex-direction: column; gap: 8px; }
.faq-item {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  overflow: hidden;
}
.faq-item[open] { border-color: var(--color-accent); }
.faq-question {
  padding: 18px 20px;
  cursor: pointer;
  font-weight: 600;
  font-size: 0.9375rem;
  list-style: none;
  display: flex;
  justify-content: space-between;
  align-items: center;
  user-select: none;
}
.faq-question::-webkit-details-marker { display: none; }
.faq-question::after { content: '+'; font-size: 1.25rem; color: var(--color-accent); line-height: 1; }
.faq-item[open] .faq-question::after { content: '−'; }
.faq-answer {
  padding: 0 20px 18px;
  font-size: 0.9rem;
  color: var(--color-text-muted);
  line-height: 1.7;
}
</style>
